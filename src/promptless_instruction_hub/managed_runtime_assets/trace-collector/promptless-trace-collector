def _enrollment_context(worker_base_url: str, dashboard_base_url: str, metadata: RuntimeMetadata) -> EnrollmentContext:
    deployment_instance_id = _worker_deployment_instance_id(worker_base_url)
    state_path = _state_path()
    with _state_file_lock(state_path):
        state = _load_state(state_path)
        host_instance_id = _host_instance_id(state)
        if state.get("host_instance_id") != host_instance_id:
            state["host_instance_id"] = host_instance_id
            _write_state(state_path, state)
    return EnrollmentContext(
        worker_base_url=worker_base_url,
        dashboard_base_url=dashboard_base_url,
        deployment_instance_id=deployment_instance_id,
        metadata=metadata,
        host_instance_id=host_instance_id,
        host_label=_host_label(),
        host_platform=_host_platform(),
    )


def _worker_deployment_instance_id(worker_base_url: str) -> str:
    response = _get_json(_worker_url(worker_base_url, "/healthz"), None, label="worker health response")
    response_mapping = _json_mapping(response)
    if response_mapping is None:
        raise CollectorError("worker health response must be a JSON object")
    deployment_instance_id = _non_empty(_string_value(response_mapping.get("deployment_instance_id")))
    if deployment_instance_id is None:
        raise CollectorError("worker health response missing deployment_instance_id")
    return deployment_instance_id


def _state_path() -> Path:
    return Path.home() / ".promptless/instruction-hub" / STATE_FILE_NAME


def _pending_plugin_update(metadata: RuntimeMetadata) -> Optional[PendingPluginUpdate]:
    current_version = metadata.plugin_version
    if current_version == "unknown":
        return None
    try:
        state_path = _state_path()
        with _state_file_lock(state_path):
            seen_versions = _json_mapping_or_empty(_load_state(state_path).get("last_seen_plugin_versions"))
        last_seen_version = _string_value(seen_versions.get(metadata.target))
    except (OSError, CollectorError):
        return None
    if last_seen_version == current_version:
        return None
    notice = (
        None
        if last_seen_version is None
        else f"Promptless Instruction Hub updated to v{current_version} (was v{last_seen_version})."
    )
    return PendingPluginUpdate(target=metadata.target, version=current_version, notice=notice)


def _record_plugin_version_seen(pending: PendingPluginUpdate) -> None:
    try:
        state_path = _state_path()
        with _state_file_lock(state_path):
            state = _load_state(state_path)
            seen_versions = _json_mapping_or_empty(state.get("last_seen_plugin_versions"))
            seen_versions[pending.target] = pending.version
            state["last_seen_plugin_versions"] = seen_versions
            _write_state(state_path, state)
    except (OSError, CollectorError):
        return


def _load_state(path: Path) -> dict[str, JsonValue]:
    if not path.exists():
        return {}
    try:
        value = json.loads(path.read_text())
    except json.JSONDecodeError as exc:
        raise CollectorError(f"host enrollment state is invalid JSON at {path}: {exc.msg}") from exc
    mapping = _json_mapping(value)
    if mapping is None:
        raise CollectorError(f"host enrollment state must be a JSON object at {path}")
    return mapping


def _write_state(path: Path, state: dict[str, JsonValue]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    _atomic_write_text(path, json.dumps(state, indent=2, sort_keys=True) + "\n")
    try:
        path.chmod(0o600)
    except OSError:
        pass


@contextmanager
def _file_lock(lock_file: BinaryIO, *, blocking: bool) -> Iterator[bool]:
    acquired = _acquire_file_lock(lock_file, blocking=blocking)
    if not acquired:
        yield False
        return
    try:
        yield True
    finally:
        _release_file_lock(lock_file)


def _acquire_file_lock(lock_file: BinaryIO, *, blocking: bool) -> bool:
    if os.name == "nt":
        return _acquire_windows_file_lock(lock_file, blocking=blocking)
    return _acquire_posix_file_lock(lock_file, blocking=blocking)


def _acquire_posix_file_lock(lock_file: BinaryIO, *, blocking: bool) -> bool:
    import fcntl

    lock_mode = fcntl.LOCK_EX
    if not blocking:
        lock_mode += fcntl.LOCK_NB
    try:
        fcntl.flock(lock_file.fileno(), lock_mode)
    except OSError:
        if blocking:
            raise
        return False
    return True


def _acquire_windows_file_lock(lock_file: BinaryIO, *, blocking: bool) -> bool:
    _prepare_windows_lock_region(lock_file)
    if not blocking:
        return _try_windows_file_lock(lock_file)

    while not _try_windows_file_lock(lock_file):
        time.sleep(0.05)
    return True


def _try_windows_file_lock(lock_file: BinaryIO) -> bool:
    import msvcrt

    try:
        msvcrt.locking(lock_file.fileno(), msvcrt.LK_NBLCK, 1)
    except OSError:
        return False
    return True


def _prepare_windows_lock_region(lock_file: BinaryIO) -> None:
    lock_file.seek(0, os.SEEK_END)
    if lock_file.tell() == 0:
        lock_file.write(b"\0")
        lock_file.flush()
    lock_file.seek(0)


def _release_file_lock(lock_file: BinaryIO) -> None:
    lock_file.seek(0)
    if os.name == "nt":
        import msvcrt

        msvcrt.locking(lock_file.fileno(), msvcrt.LK_UNLCK, 1)
        return

    import fcntl

    fcntl.flock(lock_file.fileno(), fcntl.LOCK_UN)


@contextmanager
def _state_file_lock(path: Path) -> Iterator[None]:
    lock_path = path.with_name(f"{path.name}.lock")
    lock_path.parent.mkdir(parents=True, exist_ok=True)
    with lock_path.open("a+b") as lock_file:
        with _file_lock(lock_file, blocking=True):
            yield


@contextmanager
def _enrollment_leader_lock(context: EnrollmentContext, state_path: Path) -> Iterator[bool]:
    lock_path = state_path.with_name(f"host-enrollment-{_credential_cache_key(context)}.enroll.lock")
    lock_path.parent.mkdir(parents=True, exist_ok=True)
    with lock_path.open("a+b") as lock_file:
        with _file_lock(lock_file, blocking=False) as acquired:
            if not acquired:
                yield False
                return
            yield True


def _host_instance_id(state: dict[str, JsonValue]) -> str:
    existing = _non_empty(_string_value(state.get("host_instance_id")))
    if existing is not None:
        return existing
    return f"host-{uuid.uuid4().hex}"


def _host_label() -> str:
    username = _non_empty(getpass.getuser()) or "unknown-user"
    node = _non_empty(platform.node()) or "unknown-host"
    return _truncate(f"{username}@{node}", 240)


def _host_platform() -> str:
    return _truncate(platform.platform(), 120)


def _truncate(value: str, max_length: int) -> str:
    if len(value) <= max_length:
        return value
    return value[:max_length]


def _obtain_host_credential(context: EnrollmentContext) -> Optional[HostCredential]:
    credential = _cached_host_credential(context)
    if credential is not None:
        return credential
    return _enroll_host_credential(context)


def _cached_host_credential(context: EnrollmentContext) -> Optional[HostCredential]:
    state = _load_state(_state_path())
    credentials = _json_mapping_or_empty(state.get("credentials"))
    cached_credential = _json_mapping_or_empty(credentials.get(_credential_cache_key(context)))
    credential_value = _string_value(cached_credential.get("value"))
    if credential_value is None:
        return None
    return HostCredential(
        value=credential_value,
        credential_id=_string_value(cached_credential.get("credential_id")),
        deployment_instance_id=_string_value(cached_credential.get("deployment_instance_id")),
    )


def _forget_cached_host_credential(context: EnrollmentContext) -> None:
    state_path = _state_path()
    with _state_file_lock(state_path):
        state = _load_state(state_path)
        credentials = _json_mapping_or_empty(state.get("credentials"))
        if credentials.pop(_credential_cache_key(context), None) is not None:
            state["credentials"] = credentials
            _write_state(state_path, state)


def _enroll_host_credential(context: EnrollmentContext) -> Optional[HostCredential]:
    state_path = _state_path()
    session = _load_pending_enrollment_session(context, state_path)
    if session is not None:
        return _complete_host_enrollment(context, state_path, session)
    with _enrollment_leader_lock(context, state_path) as is_enrollment_leader:
        if not is_enrollment_leader:
            return _cached_host_credential(context)
        credential = _cached_host_credential(context)
        if credential is not None:
            return credential
        session = _load_pending_enrollment_session(context, state_path)
        if session is None:
            created_session = _create_enrollment_session(context)
            session, stored_new_session = _store_pending_enrollment(context, state_path, created_session)
            if not stored_new_session:
                session = _load_pending_enrollment_session(context, state_path) or session
        return _complete_host_enrollment(context, state_path, session)


def _complete_host_enrollment(
    context: EnrollmentContext,
    state_path: Path,
    session: EnrollmentSession,
) -> Optional[HostCredential]:
    credential = _poll_enrollment_session(context, session)
    if credential is None:
        return None
    _store_host_credential(context, state_path, credential)
    return credential


def _load_pending_enrollment_session(context: EnrollmentContext, state_path: Path) -> Optional[EnrollmentSession]:
    with _state_file_lock(state_path):
        return _pending_enrollment_session(context, _load_state(state_path))


def _pending_enrollment_session(context: EnrollmentContext, state: dict[str, JsonValue]) -> Optional[EnrollmentSession]:
    pending_enrollments = _json_mapping_or_empty(state.get("pending_enrollments"))
    session_value = _json_mapping_or_empty(pending_enrollments.get(_credential_cache_key(context)))
    if not session_value:
        return None
    expires_at = _optional_datetime_value(session_value.get("expires_at"), "pending enrollment expires_at")
    if expires_at is None or expires_at <= dt.datetime.now(dt.timezone.utc):
        return None
    session_id = _string_value(session_value.get("session_id"))
    deployment_instance_id = _string_value(session_value.get("deployment_instance_id"))
    device_code = _string_value(session_value.get("device_code"))
    poll_url = _string_value(session_value.get("poll_url"))
    poll_interval_seconds = _optional_int_value(session_value.get("poll_interval_seconds"))
    if (
        session_id is None
        or deployment_instance_id is None
        or device_code is None
        or poll_url is None
        or poll_interval_seconds is None
    ):
        return None
    if deployment_instance_id != context.deployment_instance_id:
        return None
    poll_url_parts = _validate_http_url(poll_url, "pending host enrollment poll URL")
    _validate_worker_transport(poll_url_parts, "pending host enrollment poll URL")
    return EnrollmentSession(
        session_id=session_id,
        deployment_instance_id=deployment_instance_id,
        device_code=device_code,
        poll_url=poll_url,
        expires_at=expires_at,
        poll_interval_seconds=poll_interval_seconds,
    )


def _create_enrollment_session(context: EnrollmentContext) -> EnrollmentSession:
    with _EnrollmentCallbackServer() as callback_server:
        start_url = _hosted_enrollment_start_url(context, callback_server.callback_url)
        if not _open_hosted_enrollment_url(start_url):
            raise CollectorError(
                "could not open the Promptless enrollment browser. Check that a default browser is "
                "available, then restart the agent from a desktop session."
            )
        callback_payload = callback_server.wait(ENROLLMENT_POLL_DEADLINE_SECONDS)
    if callback_payload is None:
        raise CollectorError(
            "Promptless enrollment did not receive browser approval before the local callback timed out"
        )
    return _enrollment_session_from_callback(context, callback_payload)


def _hosted_enrollment_start_url(context: EnrollmentContext, callback_url: str) -> str:
    payload = {
        "callback_url": callback_url,
        "deployment_instance_id": context.deployment_instance_id,
        "target": context.metadata.target,
        "plugin_id": context.metadata.plugin_id,
        "plugin_version": context.metadata.plugin_version,
        "package_id": context.metadata.package_id,
        "bootstrap_version": context.metadata.collector_version,
        "toolchain_version": context.metadata.toolchain_version,
        "host_instance_id": context.host_instance_id,
        "host_label": context.host_label,
        "host_platform": context.host_platform,
    }
    return f"{context.dashboard_base_url}/instruction-hub/enroll/start?{urlencode(payload)}"


class _EnrollmentCallbackServer:
    """Small loopback server that receives the hosted approval result."""

    def __init__(self) -> None:
        self._event = threading.Event()
        self._payload: Optional[dict[str, str]] = None
        self._state = secrets.token_urlsafe(32)
        self._server = ThreadingHTTPServer(("127.0.0.1", 0), self._handler())
        host, port = self._server.server_address
        self.callback_url = f"http://{host}:{port}/callback?{urlencode({CALLBACK_STATE_PARAM: self._state})}"
        self._thread = threading.Thread(target=self._server.serve_forever, daemon=True)

    def __enter__(self) -> "_EnrollmentCallbackServer":
        self._thread.start()
        return self

    def __exit__(self, exc_type: object, exc_value: object, traceback: object) -> None:
        self._server.shutdown()
        self._server.server_close()
        self._thread.join(timeout=5)

    def wait(self, timeout_seconds: float) -> Optional[dict[str, str]]:
        if not self._event.wait(timeout_seconds):
            return None
        return self._payload

    def _handler(self) -> type[BaseHTTPRequestHandler]:
        callback_server = self

        class CallbackHandler(BaseHTTPRequestHandler):
            def do_GET(self) -> None:
                parsed = urlsplit(self.path)
                if parsed.path != "/callback":
                    self.send_response(404)
                    self.end_headers()
                    return
                query = parse_qs(parsed.query, keep_blank_values=False)
                if query.pop(CALLBACK_STATE_PARAM, []) != [callback_server._state]:
                    body = b"Promptless enrollment callback rejected."
                    self.send_response(403)
                    self.send_header("Content-Type", "text/plain; charset=utf-8")
                    self.send_header("Content-Length", str(len(body)))
                    self.end_headers()
                    self.wfile.write(body)
                    return
                payload: dict[str, str] = {}
                for key, values in query.items():
                    if len(values) == 1:
                        payload[key] = values[0]
                callback_server._payload = payload
                callback_server._event.set()
                body = b"Promptless enrollment approved. You can return to your agent."
                self.send_response(200)
                self.send_header("Content-Type", "text/plain; charset=utf-8")
                self.send_header("Content-Length", str(len(body)))
                self.end_headers()
                self.wfile.write(body)

            def log_message(self, format: str, *args: object) -> None:
                return

        return CallbackHandler


def _enrollment_session_from_callback(context: EnrollmentContext, payload: dict[str, str]) -> EnrollmentSession:
    if payload.get("status") != "approved":
        raise CollectorError("host enrollment callback was not approved")
    session_id = _non_empty(payload.get("session_id"))
    deployment_instance_id = _non_empty(payload.get("deployment_instance_id"))
    device_code = _non_empty(payload.get("device_code"))
    poll_url = _non_empty(payload.get("poll_url"))
    expires_at = _required_datetime_value(payload.get("expires_at"), "host enrollment callback expires_at")
    poll_interval_seconds = _int_string_value(payload.get("poll_interval_seconds"), "host enrollment poll interval")
    if session_id is None or deployment_instance_id is None or device_code is None or poll_url is None:
        raise CollectorError("host enrollment callback missing required fields")
    if deployment_instance_id != context.deployment_instance_id:
        raise CollectorError("host enrollment callback deployment_instance_id did not match worker identity")
    poll_url_parts = _validate_http_url(poll_url, "host enrollment poll URL")
    _validate_worker_transport(poll_url_parts, "host enrollment poll URL")
    if poll_interval_seconds < 1 or poll_interval_seconds > 30:
        raise CollectorError("host enrollment poll interval must be between 1 and 30 seconds")
    return EnrollmentSession(
        session_id=session_id,
        deployment_instance_id=deployment_instance_id,
        device_code=device_code,
        poll_url=poll_url,
        expires_at=expires_at,
        poll_interval_seconds=poll_interval_seconds,
    )


def _store_pending_enrollment(
    context: EnrollmentContext,
    state_path: Path,
    session: EnrollmentSession,
) -> tuple[EnrollmentSession, bool]:
    with _state_file_lock(state_path):
        state = _load_state(state_path)
        existing_session = _pending_enrollment_session(context, state)
        if existing_session is not None:
            return existing_session, False
        pending_enrollments = _json_mapping_or_empty(state.get("pending_enrollments"))
        pending_enrollments[_credential_cache_key(context)] = {
            "session_id": session.session_id,
            "deployment_instance_id": session.deployment_instance_id,
            "device_code": session.device_code,
            "poll_url": session.poll_url,
            "expires_at": session.expires_at.isoformat(),
            "poll_interval_seconds": session.poll_interval_seconds,
        }
        state["pending_enrollments"] = pending_enrollments
        _write_state(state_path, state)
        return session, True


def _poll_enrollment_session(context: EnrollmentContext, session: EnrollmentSession) -> Optional[HostCredential]:
    deadline = time.monotonic() + ENROLLMENT_POLL_DEADLINE_SECONDS
    while True:
        response = _post_json(
            session.poll_url,
            None,
            {"device_code": session.device_code},
            label="host enrollment poll response",
        )
        status = _string_value(response.get("status"))
        if status == "approved":
            host_credential = _string_value(response.get("host_credential"))
            if host_credential is None:
                raise CollectorError("approved host enrollment poll response missing host_credential")
            return HostCredential(
                value=host_credential,
                credential_id=_string_value(response.get("credential_id")),
                deployment_instance_id=session.deployment_instance_id,
            )
        if status in {"expired", "consumed"}:
            _forget_pending_enrollment(context)
            return None
        if status != "pending":
            raise CollectorError("host enrollment poll response has invalid status")
        remaining_seconds = deadline - time.monotonic()
        if remaining_seconds <= 0:
            return None
        time.sleep(min(float(session.poll_interval_seconds), remaining_seconds))


def _store_host_credential(
    context: EnrollmentContext,
    state_path: Path,
    credential: HostCredential,
) -> None:
    with _state_file_lock(state_path):
        state = _load_state(state_path)
        credentials = _json_mapping_or_empty(state.get("credentials"))
        credentials[_credential_cache_key(context)] = {
            "value": credential.value,
            "credential_id": credential.credential_id,
            "worker_base_url": context.worker_base_url,
            "deployment_instance_id": credential.deployment_instance_id,
            "target": context.metadata.target,
            "updated_at": dt.datetime.now(dt.timezone.utc).isoformat(),
        }
        state["credentials"] = credentials
        pending_enrollments = _json_mapping_or_empty(state.get("pending_enrollments"))
        pending_enrollments.pop(_credential_cache_key(context), None)
        state["pending_enrollments"] = pending_enrollments
        _write_state(state_path, state)


def _forget_pending_enrollment(context: EnrollmentContext) -> None:
    state_path = _state_path()
    with _state_file_lock(state_path):
        state = _load_state(state_path)
        pending_enrollments = _json_mapping_or_empty(state.get("pending_enrollments"))
        if pending_enrollments.pop(_credential_cache_key(context), None) is not None:
            state["pending_enrollments"] = pending_enrollments
            _write_state(state_path, state)


def _credential_cache_key(context: EnrollmentContext) -> str:
    cache_material = {
        "deployment_instance_id": context.deployment_instance_id,
        "target": context.metadata.target,
        "worker_base_url": context.worker_base_url,
    }
    return hashlib.sha256(json.dumps(cache_material, sort_keys=True).encode()).hexdigest()


def _open_hosted_enrollment_url(enrollment_url: str) -> bool:
    if os.environ.get(OPEN_BROWSER_ENV) == "0":
        if _test_url_overrides_enabled() and _is_loopback_parsed_url(urlsplit(enrollment_url)):
            _open_loopback_url_for_test(enrollment_url)
            return True
        return False
    try:
        return webbrowser.open(enrollment_url, new=2, autoraise=True)
    except webbrowser.Error:
        return False


def _open_loopback_url_for_test(enrollment_url: str) -> None:
    request = urllib.request.Request(enrollment_url, method="GET")
    try:
        with urllib.request.urlopen(request, timeout=HTTP_TIMEOUT_SECONDS) as response:
            response.read()
    except urllib.error.HTTPError as exc:
        raise CollectorError(f"hosted enrollment start request failed with HTTP {exc.code}") from exc


def _worker_url(worker_base_url: str, path: str) -> str:
    return f"{worker_base_url}{path}"


def _load_runtime_metadata(plugin_root: Optional[Path], host: Host) -> RuntimeMetadata:
    defaults = RuntimeMetadata(
        collector_version=COLLECTOR_VERSION,
        collector_channel=COLLECTOR_CHANNEL,
        collector_sha256=_self_sha256(),
        toolchain_version="unknown",
        plugin_id="unknown",
        plugin_version="unknown",
        package_id="unknown",
        target=host,
    )
    if plugin_root is None:
        return defaults
    manifest_path = plugin_root / MANAGED_RUNTIME_MANIFEST
    if not manifest_path.exists():
        return defaults
    try:
        manifest = json.loads(manifest_path.read_text())
    except (OSError, json.JSONDecodeError):
        return defaults
    mapping = _json_mapping(manifest)
    if mapping is None:
        return defaults
    runtimes = mapping.get("managed_runtimes")
    if not isinstance(runtimes, list):
        return defaults
    for runtime_value in runtimes:
        runtime = _json_mapping(runtime_value)
        if runtime is None:
            continue
        if runtime.get("id") != MANAGED_RUNTIME_ID or runtime.get("status") != "included":
            continue
        return RuntimeMetadata(
            collector_version=_string_value(runtime.get("version")) or COLLECTOR_VERSION,
            collector_channel=_string_value(runtime.get("channel")) or COLLECTOR_CHANNEL,
            collector_sha256=_string_value(runtime.get("sha256")) or _self_sha256(),
            toolchain_version=_string_value(runtime.get("toolchain_version")) or "unknown",
            plugin_id=_string_value(runtime.get("plugin_id")) or "unknown",
            plugin_version=_string_value(runtime.get("plugin_version")) or "unknown",
            package_id=_string_value(runtime.get("package_id")) or "unknown",
            target=host,
        )
    return defaults


def _validate_signed_policy(value: object, host: Host) -> HostPolicy:
    signed_policy = _json_mapping(value)
    if signed_policy is None:
        raise CollectorError("worker policy response must be a JSON object")
    for field_name in ("signature", "signed_at", "key_id"):
        if _string_value(signed_policy.get(field_name)) is None:
            raise CollectorError(f"worker signed policy response is missing {field_name}")
    policy_value = _json_mapping(signed_policy.get("policy"))
    if policy_value is None:
        raise CollectorError("worker policy response is missing policy")
    schema_version = _int_value(policy_value.get("schema_version"))
    if schema_version is None or schema_version < 2:
        raise CollectorError("worker policy schema_version must be 2 or newer")
    policy_version = _int_value(policy_value.get("policy_version"))
    if policy_version is None or policy_version < 1:
        raise CollectorError("worker policy policy_version must be a positive integer")

    enabled_hosts = _host_tuple(policy_value.get("enabled_hosts"), "enabled_hosts")
    if host not in enabled_hosts:
        raise CollectorError(f"worker policy does not enable host {host}")

    trace_collection_value = _json_mapping(policy_value.get("trace_collection"))
    if trace_collection_value is None:
        raise CollectorError("worker policy is missing trace_collection")
    trace_collection = _validate_trace_collection(trace_collection_value, host)

    capture_policy = _validate_capture_policy(policy_value.get("capture_policy"))
    plugin_permissions_value = _json_mapping(policy_value.get("plugin_permissions"))
    if plugin_permissions_value is None:
        raise CollectorError("worker policy is missing plugin_permissions")
    plugin_permissions = _validate_plugin_permissions(plugin_permissions_value)
    required_bootstrap_version = _string_value(policy_value.get("required_bootstrap_version"))
    return HostPolicy(
        policy_version=policy_version,
        trace_collection=trace_collection,
        enabled_hosts=enabled_hosts,
        capture_policy=capture_policy,
        plugin_permissions=plugin_permissions,
        required_bootstrap_version=required_bootstrap_version,
    )


def _validate_trace_collection(value: dict[str, JsonValue], host: Host) -> TraceCollectionPolicy:
    upload_endpoint = _string_value(value.get("upload_endpoint"))
    if upload_endpoint is None:
        raise CollectorError("trace_collection.upload_endpoint must be a string")
    _validate_upload_endpoint(upload_endpoint)
    enabled_sources = _host_tuple(value.get("enabled_sources"), "trace_collection.enabled_sources")
    if host not in enabled_sources:
        raise CollectorError(f"worker policy does not enable source {host}")
    raw_max_batch_bytes = _int_value(value.get("max_batch_bytes"))
    max_batch_bytes = raw_max_batch_bytes if raw_max_batch_bytes is not None else 10 * 1024 * 1024
    if max_batch_bytes <= 0:
        raise CollectorError("trace_collection.max_batch_bytes must be positive")
    if max_batch_bytes > MAX_TRACE_BATCH_BYTES:
        raise CollectorError(
            f"trace_collection.max_batch_bytes must not exceed {MAX_TRACE_BATCH_BYTES} bytes"
        )
    native_roots = _native_root_tuple(value.get("native_roots"))
    invalid_root_sources = sorted({root.source for root in native_roots if root.source not in enabled_sources})
    if invalid_root_sources:
        raise CollectorError("trace_collection.native_roots source must be enabled by trace_collection.enabled_sources")
    return TraceCollectionPolicy(
        upload_endpoint=upload_endpoint,
        enabled_sources=enabled_sources,
        forward_only_first_install=_bool_value(value.get("forward_only_first_install"), default=True),
        include_in_progress_traces=_bool_value(value.get("include_in_progress_traces"), default=True),
        max_batch_bytes=max_batch_bytes,
        native_roots=native_roots,
    )


def _validate_plugin_permissions(value: dict[str, JsonValue]) -> PluginPermissions:
    allow_network = _required_bool(value.get("allow_network"), "plugin_permissions.allow_network")
    allowed_hosts = _string_tuple(value.get("allowed_hosts"), "plugin_permissions.allowed_hosts")
    if allow_network and not allowed_hosts:
        raise CollectorError("plugin_permissions.allowed_hosts is required when allow_network is true")

    allow_local_file_read = _required_bool(
        value.get("allow_local_file_read"),
        "plugin_permissions.allow_local_file_read",
    )
    raw_allowed_read_roots = _string_tuple(
        value.get("allowed_read_roots"),
        "plugin_permissions.allowed_read_roots",
    )
    if allow_local_file_read and not raw_allowed_read_roots:
        raise CollectorError("plugin_permissions.allowed_read_roots is required when allow_local_file_read is true")
    allowed_read_roots = tuple(
        _resolve_permission_path(root, "plugin_permissions.allowed_read_roots")
        for root in raw_allowed_read_roots
    )
    return PluginPermissions(
        allow_network=allow_network,
        allowed_hosts=allowed_hosts,
        allow_local_file_read=allow_local_file_read,
        allowed_read_roots=allowed_read_roots,
    )


def _required_bool(value: Optional[JsonValue], field_name: str) -> bool:
    if isinstance(value, bool):
        return value
    raise CollectorError(f"{field_name} must be a boolean")


def _string_tuple(value: Optional[JsonValue], field_name: str) -> tuple[str, ...]:
    if value is None:
        return ()
    if not isinstance(value, list):
        raise CollectorError(f"{field_name} must be an array")
    items: list[str] = []
    for item in value:
        item_value = _string_value(item)
        if item_value is None or item_value.strip() == "":
            raise CollectorError(f"{field_name} must contain only non-empty strings")
        if item_value not in items:
            items.append(item_value)
    return tuple(items)


def _validate_capture_policy(value: Optional[JsonValue]) -> dict[str, str]:
    if not isinstance(value, dict):
        raise CollectorError("policy.capture_policy must be an object")
    capture_policy: dict[str, str] = {}
    for key in CAPTURE_POLICY_REQUIRED_KEYS:
        policy_value = _string_value(value.get(key))
        if policy_value is None:
            raise CollectorError(f"policy.capture_policy.{key} must be a string")
        if policy_value not in CAPTURE_POLICY_VALUES:
            raise CollectorError(f"policy.capture_policy.{key} must be one of {sorted(CAPTURE_POLICY_VALUES)}")
        capture_policy[key] = policy_value
    return capture_policy


def _host_tuple(value: Optional[JsonValue], field_name: str) -> tuple[Host, ...]:
    if not isinstance(value, list) or not value:
        raise CollectorError(f"{field_name} must be a non-empty array")
    hosts: list[Host] = []
    for item in value:
        host = _host_value(item)
        if host is None:
            raise CollectorError(f"{field_name} must contain only codex or claude")
        if host not in hosts:
            hosts.append(host)
    return tuple(hosts)


def _native_root_tuple(value: Optional[JsonValue]) -> tuple[NativeRoot, ...]:
    if value is None:
        return ()
    if not isinstance(value, list):
        raise CollectorError("trace_collection.native_roots must be an array")
    roots: list[NativeRoot] = []
    for item in value:
        mapping = _json_mapping(item)
        if mapping is None:
            raise CollectorError("trace_collection.native_roots entries must be objects")
        source = _host_value(mapping.get("source"))
        glob_pattern = _string_value(mapping.get("glob"))
        if source is None or glob_pattern is None:
            raise CollectorError("trace_collection.native_roots entries require source and glob")
        roots.append(NativeRoot(source=source, glob_pattern=glob_pattern))
    return tuple(roots)


def _native_roots_for_host(host: Host, policy: TraceCollectionPolicy) -> tuple[NativeRoot, ...]:
    configured = tuple(root for root in policy.native_roots if root.source == host)
    if configured:
        return configured
    if host == "claude":
        return (NativeRoot(source=host, glob_pattern="~/.claude/projects/**/*.jsonl"),)
    return (NativeRoot(source=host, glob_pattern="~/.codex/**/*.jsonl"),)


def _require_network_allowed_for_url(url: str, permissions: PluginPermissions, field_name: str) -> None:
    if not permissions.allow_network:
        raise CollectorError(f"worker policy does not allow network access for {field_name}")
    parsed = urlsplit(url)
    hostname = parsed.hostname
    if hostname is None:
        raise CollectorError(f"{field_name} must include a hostname")
    if hostname not in permissions.allowed_hosts and parsed.netloc not in permissions.allowed_hosts:
        raise CollectorError(f"{field_name} host is not allowed by plugin_permissions.allowed_hosts")


def _validate_native_root_permissions(roots: tuple[NativeRoot, ...], permissions: PluginPermissions) -> None:
    if not permissions.allow_local_file_read:
        raise CollectorError("worker policy does not allow local native trace file reads")
    for root in roots:
        glob_prefix = _glob_static_prefix(root.glob_pattern)
        if not _path_is_allowed_read_path(glob_prefix, permissions.allowed_read_roots):
            raise CollectorError("trace_collection.native_roots glob is outside plugin_permissions.allowed_read_roots")


def _expand_native_paths(roots: tuple[NativeRoot, ...], permissions: PluginPermissions) -> tuple[Path, ...]:
    paths: dict[str, Path] = {}
    for root in roots:
        expanded_pattern = os.path.expandvars(os.path.expanduser(root.glob_pattern))
        for candidate in glob.glob(expanded_pattern, recursive=True):
            path = Path(candidate).expanduser()
            if not path.is_file():
                continue
            try:
                resolved_path = path.resolve(True)
            except (OSError, RuntimeError):
                continue
            if not _path_is_allowed_read_path(resolved_path, permissions.allowed_read_roots):
                raise CollectorError("native trace file is outside plugin_permissions.allowed_read_roots")
            paths[str(resolved_path)] = resolved_path
    return tuple(paths[key] for key in sorted(paths))


def _glob_static_prefix(glob_pattern: str) -> Path:
    expanded_pattern = os.path.expandvars(os.path.expanduser(glob_pattern))
    parts: list[str] = []
    for part in Path(expanded_pattern).parts:
        if _path_part_has_glob_magic(part):
            break
        parts.append(part)
    if not parts:
        raise CollectorError("trace_collection.native_roots glob must include a non-glob path prefix")
    return _resolve_permission_path(str(Path(*parts)), "trace_collection.native_roots.glob")


def _path_part_has_glob_magic(part: str) -> bool:
    return "*" in part or "?" in part or "[" in part


def _resolve_permission_path(raw_path: str, field_name: str) -> Path:
    expanded_path = os.path.expandvars(os.path.expanduser(raw_path))
    path = Path(expanded_path)
    if not path.is_absolute():
        raise CollectorError(f"{field_name} entries must resolve to absolute paths")
    return path.resolve(False)


def _path_is_allowed_read_path(path: Path, allowed_roots: tuple[Path, ...]) -> bool:
    resolved_path = path.resolve(False)
    for root in allowed_roots:
        try:
            resolved_path.relative_to(root)
        except ValueError:
            continue
        return True
    return False


def _ledger_path() -> Path:
    raw_path = os.environ.get("PROMPTLESS_TRACE_COLLECTOR_LEDGER")
    if raw_path:
        return Path(raw_path).expanduser()
    return Path.home() / ".promptless/instruction-hub" / LEDGER_FILE_NAME


def _legacy_ledger_paths(global_path: Path) -> tuple[Path, ...]:
    if os.environ.get("PROMPTLESS_TRACE_COLLECTOR_LEDGER"):
        return ()

    paths: list[Path] = []
    seen = {str(global_path)}
    for raw_dir in (os.environ.get("PLUGIN_DATA"), os.environ.get("CLAUDE_PLUGIN_DATA")):
        if not raw_dir:
            continue
        legacy_path = Path(raw_dir).expanduser() / LEDGER_FILE_NAME
        legacy_key = str(legacy_path)
        if legacy_key in seen:
            continue
        seen.add(legacy_key)
        paths.append(legacy_path)
    return tuple(paths)


@contextmanager
def _ledger_lock(path: Path) -> Iterator[None]:
    lock_path = path.with_name(f"{path.name}.lock")
    lock_path.parent.mkdir(parents=True, exist_ok=True)
    with lock_path.open("a+b") as lock_file:
        with _file_lock(lock_file, blocking=True):
            yield


def _load_ledger(path: Path) -> SourceLedger:
    disk_state = _ledger_state_from_disk(path)
    if disk_state is None:
        return _recover_corrupt_ledger(path)

    sources, legacy_ledger_imports = disk_state
    ledger = SourceLedger(
        path=path,
        is_new=not path.exists(),
        sources=sources,
        legacy_ledger_imports=legacy_ledger_imports,
    )
    _import_legacy_ledgers(ledger)
    return ledger


def _import_legacy_ledgers(ledger: SourceLedger) -> None:
    imported_sources = False
    for legacy_path in _legacy_ledger_paths(ledger.path):
        legacy_key = str(legacy_path)
        if legacy_key in ledger.legacy_ledger_imports:
            continue
        legacy_state = _ledger_state_from_disk(legacy_path)
        if legacy_state is None:
            continue
        legacy_sources, _legacy_imports = legacy_state
        if not legacy_sources:
            continue
        for source_key, offset in legacy_sources.items():
            ledger.sources[source_key] = max(ledger.sources.get(source_key, 0), offset)
        ledger.legacy_ledger_imports.add(legacy_key)
        imported_sources = True

    if imported_sources:
        _save_ledger(ledger)


def _recover_corrupt_ledger(path: Path) -> SourceLedger:
    backup_path = _corrupt_ledger_backup_path(path)
    path.rename(backup_path)
    return SourceLedger(
        path=path,
        is_new=False,
        sources={},
        drift_reports=[
            {
                "kind": "trace_ledger_corrupt",
                "message": "Local trace ledger was corrupt and has been moved aside",
                "repaired": True,
                "details": {"backup_path": str(backup_path)},
            }
        ],
        recover_to_current_end=True,
    )


def _corrupt_ledger_backup_path(path: Path) -> Path:
    timestamp = dt.datetime.now(dt.timezone.utc).strftime("%Y%m%dT%H%M%SZ")
    suffix = secrets.token_hex(4)
    return path.with_name(f"{path.name}.corrupt-{timestamp}-{suffix}")


def _ledger_sources_from_disk(path: Path) -> dict[str, int]:
    disk_state = _ledger_state_from_disk(path)
    if disk_state is None:
        return {}
    sources, _legacy_ledger_imports = disk_state
    return sources


def _ledger_state_from_disk(path: Path) -> Optional[tuple[dict[str, int], set[str]]]:
    if not path.exists():
        return {}, set()
    try:
        value = json.loads(path.read_text())
    except json.JSONDecodeError:
        return None
    mapping = _json_mapping(value)
    if mapping is None:
        return None
    sources = _ledger_sources_from_mapping(mapping)
    if sources is None:
        return None
    return sources, _legacy_ledger_imports_from_mapping(mapping)


def _ledger_sources_from_mapping(mapping: dict[str, JsonValue]) -> Optional[dict[str, int]]:
    raw_sources = mapping.get("sources")
    if not isinstance(raw_sources, dict):
        return None
    sources: dict[str, int] = {}
    for key, offset_value in raw_sources.items():
        if not isinstance(key, str):
            return None
        offset = _int_value(offset_value)
        if offset is None or offset < 0:
            return None
        sources[key] = offset
    return sources


def _legacy_ledger_imports_from_mapping(mapping: dict[str, JsonValue]) -> set[str]:
    raw_imports = mapping.get("legacy_ledger_imports")
    if not isinstance(raw_imports, list):
        return set()
    return {value for value in raw_imports if isinstance(value, str)}


def _save_ledger(ledger: SourceLedger) -> None:
    ledger.path.parent.mkdir(parents=True, exist_ok=True)
    disk_state = _ledger_state_from_disk(ledger.path)
    if disk_state is None:
        merged_sources: dict[str, int] = {}
        legacy_ledger_imports: set[str] = set()
    else:
        merged_sources, legacy_ledger_imports = disk_state
    for key, offset in ledger.sources.items():
        if key in ledger.reset_sources:
            merged_sources[key] = offset
        else:
            merged_sources[key] = max(merged_sources.get(key, 0), offset)
    legacy_ledger_imports.update(ledger.legacy_ledger_imports)
    payload: dict[str, JsonValue] = {
        "schema_version": 1,
        "sources": {key: merged_sources[key] for key in sorted(merged_sources)},
    }
    if legacy_ledger_imports:
        payload["legacy_ledger_imports"] = sorted(legacy_ledger_imports)
    content = json.dumps(payload, indent=2, sort_keys=True) + "\n"
    temp_path: Optional[Path] = None
    try:
        with tempfile.NamedTemporaryFile(
            "w",
            encoding="utf-8",
            dir=ledger.path.parent,
            prefix=f".{ledger.path.name}.",
            delete=False,
        ) as temp_file:
            temp_path = Path(temp_file.name)
            temp_file.write(content)
            temp_file.flush()
            os.fsync(temp_file.fileno())
        os.replace(temp_path, ledger.path)
        _fsync_directory(ledger.path.parent)
    finally:
        if temp_path is not None and temp_path.exists():
            temp_path.unlink()
    ledger.sources = merged_sources
    ledger.reset_sources.clear()
    ledger.legacy_ledger_imports = legacy_ledger_imports
    ledger.recover_to_current_end = False
    ledger.is_new = False


def _fsync_directory(path: Path) -> None:
    if os.name == "nt":
        return
    directory_fd = os.open(path, os.O_RDONLY)
    try:
        os.fsync(directory_fd)
    finally:
        os.close(directory_fd)


def _baseline_sources(ledger: SourceLedger, source_paths: tuple[Path, ...]) -> None:
    for path in source_paths:
        complete_end = _complete_end_offset(path)
        ledger.sources[str(path)] = complete_end


def _iter_source_events(
    source_paths: tuple[Path, ...],
    ledger: SourceLedger,
    *,
    max_chunk_bytes: int,
) -> Iterator[SourceEvent]:
    if max_chunk_bytes <= 0:
        raise CollectorError("native trace upload chunk limit must be positive")

    for path in source_paths:
        path_key = str(path)
        start_offset = ledger.sources.get(path_key, 0)
        file_size = path.stat().st_size
        if start_offset > file_size:
            start_offset = 0
            ledger.sources[path_key] = 0
            ledger.reset_sources.add(path_key)
        snapshot_end_offset = _complete_end_offset(path)
        if start_offset >= snapshot_end_offset:
            continue
        with path.open("rb") as file:
            file.seek(start_offset)
            for source_event in _stream_source_events(
                path,
                file,
                start_offset,
                snapshot_end_offset=snapshot_end_offset,
                max_chunk_bytes=max_chunk_bytes,
            ):
                yield source_event


def _complete_end_offset(path: Path) -> int:
    complete_end = 0
    offset = 0
    with path.open("rb") as file:
        while True:
            chunk = file.read(SOURCE_READ_BLOCK_BYTES)
            if not chunk:
                return complete_end
            last_newline = chunk.rfind(b"\n")
            if last_newline != -1:
                complete_end = offset + last_newline + 1
            offset += len(chunk)


def _stream_source_events(
    path: Path,
    file: BinaryIO,
    start_offset: int,
    *,
    snapshot_end_offset: int,
    max_chunk_bytes: int,
) -> Iterator[SourceEvent]:
    path_hash = _path_hash(path)
    chunk_start_offset = start_offset
    chunk = bytearray()
    while file.tell() < snapshot_end_offset:
        line_start_offset = file.tell()
        read_limit = min(max_chunk_bytes + 1, snapshot_end_offset - line_start_offset)
        line = file.readline(read_limit)
        if not line:
            break
        if len(line) > max_chunk_bytes or not line.endswith(b"\n"):
            if chunk:
                yield _source_event(
                    path=path,
                    path_hash=path_hash,
                    start_offset=chunk_start_offset,
                    content=bytes(chunk),
                )
            if line.endswith(b"\n"):
                yield _oversized_source_event(
                    path=path,
                    path_hash=path_hash,
                    start_offset=line_start_offset,
                    content=line,
                    reason="decoded_size",
                )
            else:
                yield _read_oversized_source_event(
                    path=path,
                    path_hash=path_hash,
                    file=file,
                    start_offset=line_start_offset,
                    first_piece=line,
                    snapshot_end_offset=snapshot_end_offset,
                    reason="decoded_size",
                )
            chunk = bytearray()
            chunk_start_offset = file.tell()
            continue

        line_encoded_size = _encoded_content_size(line)
        if line_encoded_size > max_chunk_bytes:
            if chunk:
                yield _source_event(
                    path=path,
                    path_hash=path_hash,
                    start_offset=chunk_start_offset,
                    content=bytes(chunk),
                )
            yield _oversized_source_event(
                path=path,
                path_hash=path_hash,
                start_offset=line_start_offset,
                content=line,
                reason="encoded_size",
            )
            chunk = bytearray()
            chunk_start_offset = file.tell()
            continue

        if chunk:
            candidate = bytes(chunk) + line
            if len(candidate) > max_chunk_bytes or _encoded_content_size(candidate) > max_chunk_bytes:
                yield _source_event(
                    path=path,
                    path_hash=path_hash,
                    start_offset=chunk_start_offset,
                    content=bytes(chunk),
                )
                chunk = bytearray(line)
                chunk_start_offset = line_start_offset
                continue
        else:
            chunk_start_offset = line_start_offset
        chunk.extend(line)

    if chunk:
        yield _source_event(
            path=path,
            path_hash=path_hash,
            start_offset=chunk_start_offset,
            content=bytes(chunk),
        )


def _source_event(*, path: Path, path_hash: str, start_offset: int, content: bytes) -> SourceEvent:
    return SourceEvent(
        kind="jsonl_range",
        path=path,
        path_hash=path_hash,
        start_offset=start_offset,
        end_offset=start_offset + len(content),
        byte_count=len(content),
        content_sha256=hashlib.sha256(content).hexdigest(),
        content=content,
        oversized_reason=None,
    )


def _oversized_source_event(
    *,
    path: Path,
    path_hash: str,
    start_offset: int,
    content: bytes,
    reason: str,
) -> SourceEvent:
    return SourceEvent(
        kind="oversized_record",
        path=path,
        path_hash=path_hash,
        start_offset=start_offset,
        end_offset=start_offset + len(content),
        byte_count=len(content),
        content_sha256=hashlib.sha256(content).hexdigest(),
        content=None,
        oversized_reason=reason,
    )


def _read_oversized_source_event(
    *,
    path: Path,
    path_hash: str,
    file: BinaryIO,
    start_offset: int,
    first_piece: bytes,
    snapshot_end_offset: int,
    reason: str,
) -> SourceEvent:
    content_hash = hashlib.sha256()
    content_hash.update(first_piece)
    byte_count = len(first_piece)
    while file.tell() < snapshot_end_offset:
        remaining = snapshot_end_offset - file.tell()
        block = file.read(min(SOURCE_READ_BLOCK_BYTES, remaining))
        if not block:
            break
        newline_index = block.find(b"\n")
        if newline_index == -1:
            content_hash.update(block)
            byte_count += len(block)
            continue
        record_tail = block[: newline_index + 1]
        content_hash.update(record_tail)
        byte_count += len(record_tail)
        extra_bytes = len(block) - len(record_tail)
        if extra_bytes:
            file.seek(file.tell() - extra_bytes)
        break

    return SourceEvent(
        kind="oversized_record",
        path=path,
        path_hash=path_hash,
        start_offset=start_offset,
        end_offset=start_offset + byte_count,
        byte_count=byte_count,
        content_sha256=content_hash.hexdigest(),
        content=None,
        oversized_reason=reason,
    )


def _encoded_content_size(content: bytes) -> int:
    return len(base64.b64encode(gzip.compress(content)))


def _advance_ledger(ledger: SourceLedger, events: list[SourceEvent]) -> None:
    for source_event in events:
        path_key = str(source_event.path)
        ledger.sources[path_key] = max(ledger.sources.get(path_key, 0), source_event.end_offset)


def _iter_upload_batches(
    *,
    host: Host,
    metadata: RuntimeMetadata,
    policy: HostPolicy,
    events: Iterator[SourceEvent],
    lifecycle_event: Optional[LifecycleEvent],
) -> Iterator[UploadBatch]:
    current_chunks: list[JsonValue] = []
    current_events: list[SourceEvent] = []
    current_encoded_bytes = 0
    current_decoded_bytes = 0

    for source_event in events:
        chunk = _upload_event_payload(source_event, lifecycle_event)
        encoded_size = _upload_payload_encoded_size(chunk)
        decoded_size = source_event.byte_count if source_event.kind == "jsonl_range" else 0
        if encoded_size > policy.trace_collection.max_batch_bytes:
            raise CollectorError("native trace chunk exceeds trace_collection.max_batch_bytes")
        if decoded_size > policy.trace_collection.max_batch_bytes:
            raise CollectorError("native trace chunk exceeds trace_collection.max_batch_bytes")
        batch_is_full = current_chunks and (
            current_encoded_bytes + encoded_size > policy.trace_collection.max_batch_bytes
            or current_decoded_bytes + decoded_size > policy.trace_collection.max_batch_bytes
            or len(current_chunks) >= MAX_UPLOAD_CHUNKS_PER_BATCH
        )
        if batch_is_full:
            yield _upload_batch(
                host=host,
                metadata=metadata,
                policy=policy,
                chunks=current_chunks,
                events=current_events,
            )
            current_chunks = []
            current_events = []
            current_encoded_bytes = 0
            current_decoded_bytes = 0
        current_chunks.append(chunk)
        current_events.append(source_event)
        current_encoded_bytes += encoded_size
        current_decoded_bytes += decoded_size

    if current_chunks:
        yield _upload_batch(
            host=host,
            metadata=metadata,
            policy=policy,
            chunks=current_chunks,
            events=current_events,
        )


def _upload_event_payload(source_event: SourceEvent, lifecycle_event: Optional[LifecycleEvent]) -> dict[str, JsonValue]:
    if source_event.kind == "jsonl_range":
        content = source_event.content
        if content is None:
            raise CollectorError("native trace upload range is missing content")
        compressed = gzip.compress(content)
        return {
            "kind": "jsonl_range",
            "source_path_hash": source_event.path_hash,
            "start_offset": source_event.start_offset,
            "end_offset": source_event.end_offset,
            "line_count": len(content.splitlines()),
            "content_sha256": source_event.content_sha256,
            "content_gzip_base64": base64.b64encode(compressed).decode("ascii"),
            "lifecycle_event": lifecycle_event,
        }
    if source_event.oversized_reason is None:
        raise CollectorError("native trace skipped record is missing oversized reason")
    return {
        "kind": "oversized_record",
        "source_path_hash": source_event.path_hash,
        "start_offset": source_event.start_offset,
        "end_offset": source_event.end_offset,
        "byte_count": source_event.byte_count,
        "content_sha256": source_event.content_sha256,
        "oversized_reason": source_event.oversized_reason,
        "lifecycle_event": lifecycle_event,
    }


def _upload_payload_encoded_size(payload: dict[str, JsonValue]) -> int:
    encoded_content = _string_value(payload.get("content_gzip_base64"))
    if encoded_content is None:
        return 0
    return len(encoded_content.encode("ascii"))


def _upload_batch(
    *,
    host: Host,
    metadata: RuntimeMetadata,
    policy: HostPolicy,
    chunks: list[JsonValue],
    events: list[SourceEvent],
) -> UploadBatch:
    request: dict[str, JsonValue] = {
        "batch_id": _stable_upload_batch_id(host, policy, chunks),
        "source": host,
        "host": host,
        "policy_version": policy.policy_version,
        "collector_version": metadata.collector_version,
        "plugin_version": metadata.plugin_version,
        "uploaded_at": _utc_now_iso(),
        "chunks": chunks,
    }
    raw_artifact_count = sum(1 for event in events if event.kind == "jsonl_range")
    skipped_record_count = sum(1 for event in events if event.kind == "oversized_record")
    return UploadBatch(
        request=request,
        events=list(events),
        raw_artifact_count=raw_artifact_count,
        skipped_record_count=skipped_record_count,
    )


def _stable_upload_batch_id(host: Host, policy: HostPolicy, chunks: list[JsonValue]) -> str:
    identities: list[dict[str, JsonValue]] = []
    for chunk_value in chunks:
        chunk = _json_mapping(chunk_value)
        identities.append(
            {
                "kind": _string_value(chunk.get("kind")) or "jsonl_range",
                "source_path_hash": _string_value(chunk.get("source_path_hash")) or "",
                "start_offset": _int_value(chunk.get("start_offset")) or 0,
                "end_offset": _int_value(chunk.get("end_offset")) or 0,
                "content_sha256": _string_value(chunk.get("content_sha256")) or "",
            }
        )
    stable_identity = {
        "host": host,
        "policy_version": policy.policy_version,
        "chunks": identities,
    }
    encoded_identity = json.dumps(stable_identity, separators=(",", ":"), sort_keys=True).encode("utf-8")
    digest = hashlib.sha256(encoded_identity).hexdigest()
    return f"{host}-{policy.policy_version}-{digest[:32]}"


def _post_upload_batch(
    url: str,
    token: str,
    policy: HostPolicy,
    upload_batch: UploadBatch,
) -> None:
    response = _post_json(url, token, upload_batch.request)
    _validate_upload_response(response, upload_batch.request, policy.policy_version, url)


def _post_check_in(
    url: str,
    token: str,
    host: Host,
    metadata: RuntimeMetadata,
    policy: HostPolicy,
    *,
    status: CollectorStatus,
    needs_restart: bool,
    ledger_path: Path,
    root_count: int,
    drift_reports: list[dict[str, JsonValue]],
) -> None:
    capture_policy = policy.capture_policy
    payload = {
        "host": host,
        "plugin_version": metadata.plugin_version,
        "policy_version": policy.policy_version,
        "status": status,
        "needs_restart": needs_restart,
        "effective_config": {
            "host": host,
            "configured": status == "configured",
            "trace_upload_endpoint": policy.trace_collection.upload_endpoint,
            "native_root_count": root_count,
            "source_ledger_path": str(ledger_path),
            "user_prompts_enabled": _capture_enabled(capture_policy, "user_prompts"),
            "assistant_messages_enabled": _capture_enabled(capture_policy, "assistant_messages"),
            "reasoning_enabled": _capture_enabled(capture_policy, "reasoning"),
            "tool_inputs_enabled": _capture_enabled(capture_policy, "tool_inputs"),
            "tool_outputs_enabled": _capture_enabled(capture_policy, "tool_outputs"),
            "raw_native_artifacts_enabled": _capture_enabled(capture_policy, "raw_native_artifacts"),
            "managed_config_detected": True,
        },
        "drift_reports": drift_reports,
        "checked_at": _utc_now_iso(),
        "bootstrap_version": metadata.collector_version,
    }
    response = _post_json(url, token, payload)
    _validate_check_in_response(response, policy.policy_version, url)


def _validate_check_in_response(response: dict[str, JsonValue], expected_policy_version: int, url: str) -> None:
    _require_accepted_response(response, url)
    policy_version = _int_value(response.get("policy_version"))
    if policy_version != expected_policy_version:
        raise CollectorError(f"worker response policy_version did not match request for {urlsplit(url).path}")


def _validate_upload_response(
    response: dict[str, JsonValue],
    request: dict[str, JsonValue],
    expected_policy_version: int,
    url: str,
) -> None:
    _require_accepted_response(response, url)
    request_batch_id = _string_value(request.get("batch_id"))
    if _string_value(response.get("batch_id")) != request_batch_id:
        raise CollectorError(f"worker response batch_id did not match request for {urlsplit(url).path}")
    policy_version = _int_value(response.get("policy_version"))
    if policy_version != expected_policy_version:
        raise CollectorError(f"worker response policy_version did not match request for {urlsplit(url).path}")
    request_chunks = request.get("chunks")
    expected_raw_artifacts = 0
    expected_skipped_records = 0
    if isinstance(request_chunks, list):
        for chunk_value in request_chunks:
            chunk = _json_mapping(chunk_value)
            if chunk is None:
                continue
            if chunk.get("kind") == "oversized_record":
                expected_skipped_records += 1
            else:
                expected_raw_artifacts += 1
    raw_artifact_count = _int_value(response.get("raw_artifact_count"))
    if raw_artifact_count != expected_raw_artifacts:
        raise CollectorError(f"worker response raw_artifact_count did not match request for {urlsplit(url).path}")
    skipped_record_count = _int_value(response.get("skipped_record_count"))
    if skipped_record_count != expected_skipped_records:
        raise CollectorError(f"worker response skipped_record_count did not match request for {urlsplit(url).path}")
    _validate_acknowledged_ranges(response, request, url)
    for field in ("raw_artifact_count", "trace_count", "event_count", "unparsed_record_count"):
        value = _int_value(response.get(field))
        if value is None or value < 0:
            raise CollectorError(f"worker response {field} must be a non-negative integer")
    if skipped_record_count is not None and skipped_record_count < 0:
        raise CollectorError(f"worker response skipped_record_count must be a non-negative integer")


def _validate_acknowledged_ranges(
    response: dict[str, JsonValue],
    request: dict[str, JsonValue],
    url: str,
) -> None:
    actual_value = response.get("acknowledged_ranges")
    if not isinstance(actual_value, list):
        raise CollectorError(f"worker response acknowledged_ranges must be an array for {urlsplit(url).path}")
    expected_ranges = _expected_acknowledged_ranges(request)
    if len(actual_value) != len(expected_ranges):
        raise CollectorError(f"worker response acknowledged_ranges did not match request for {urlsplit(url).path}")
    for index, expected_range in enumerate(expected_ranges):
        actual_range = _json_mapping(actual_value[index])
        if actual_range is None:
            raise CollectorError(f"worker response acknowledged_ranges did not match request for {urlsplit(url).path}")
        actual_identity: dict[str, JsonValue] = {
            "kind": actual_range.get("kind"),
            "source_path_hash": actual_range.get("source_path_hash"),
            "start_offset": actual_range.get("start_offset"),
            "end_offset": actual_range.get("end_offset"),
            "content_sha256": actual_range.get("content_sha256"),
        }
        if actual_identity != expected_range:
            raise CollectorError(f"worker response acknowledged_ranges did not match request for {urlsplit(url).path}")


def _expected_acknowledged_ranges(request: dict[str, JsonValue]) -> list[dict[str, JsonValue]]:
    request_chunks = request.get("chunks")
    if not isinstance(request_chunks, list):
        raise CollectorError("collector upload request chunks must be an array")
    expected_ranges: list[dict[str, JsonValue]] = []
    for chunk_value in request_chunks:
        chunk = _json_mapping(chunk_value)
        if chunk is None:
            raise CollectorError("collector upload request chunks must contain objects")
        kind = _string_value(chunk.get("kind"))
        source_path_hash = _string_value(chunk.get("source_path_hash"))
        start_offset = _int_value(chunk.get("start_offset"))
        end_offset = _int_value(chunk.get("end_offset"))
        content_sha256 = _string_value(chunk.get("content_sha256"))
        if (
            kind is None
            or source_path_hash is None
            or start_offset is None
            or end_offset is None
            or content_sha256 is None
        ):
            raise CollectorError("collector upload request chunk is missing acknowledged range fields")
        expected_ranges.append(
            {
                "kind": kind,
                "source_path_hash": source_path_hash,
                "start_offset": start_offset,
                "end_offset": end_offset,
                "content_sha256": content_sha256,
            }
        )
    return expected_ranges


def _require_accepted_response(response: dict[str, JsonValue], url: str) -> None:
    if response.get("accepted") is not True:
        raise CollectorError(f"worker did not accept request for {urlsplit(url).path}")


def _capture_enabled(capture_policy: dict[str, str], key: str) -> Optional[bool]:
    value = capture_policy.get(key)
    if value is None:
        return None
    return value == "full_local_default"


def _trace_upload_suppression(
    policy: HostPolicy,
    host: Host,
    lifecycle_event: Optional[LifecycleEvent],
) -> Optional[UploadSuppression]:
    disabled_capture_keys = _native_upload_disabled_capture_keys(policy.capture_policy)
    if disabled_capture_keys:
        return UploadSuppression(
            reason="capture_policy",
            advance_ledger_to_current_end=True,
            drift_report={
                "kind": "trace_upload_suppressed_by_capture_policy",
                "message": "Native trace upload is suppressed because policy does not allow full raw JSONL capture",
                "repaired": False,
                "details": {"capture_keys": disabled_capture_keys},
            },
        )
    if not policy.trace_collection.include_in_progress_traces and not _is_terminal_lifecycle_event(
        host, lifecycle_event
    ):
        return UploadSuppression(
            reason="in_progress_trace",
            advance_ledger_to_current_end=False,
            drift_report={
                "kind": "trace_upload_waiting_for_session_end",
                "message": "Native trace upload is waiting for a session-end hook per policy",
                "repaired": False,
                "details": {"host": host, "lifecycle_event": lifecycle_event},
            },
        )
    return None


def _is_terminal_lifecycle_event(host: Host, lifecycle_event: Optional[LifecycleEvent]) -> bool:
    if host == "codex":
        return lifecycle_event == "stop"
    return lifecycle_event == "session_end"


def _native_upload_disabled_capture_keys(capture_policy: dict[str, str]) -> list[str]:
    return sorted(key for key in CAPTURE_POLICY_REQUIRED_KEYS if capture_policy.get(key) != "full_local_default")


def _get_json(url: str, token: Optional[str], *, label: str = "worker response") -> JsonValue:
    request = urllib.request.Request(url, headers=_auth_headers(token), method="GET")
    try:
        with urllib.request.urlopen(request, timeout=HTTP_TIMEOUT_SECONDS) as response:
            return _load_json_bytes(response.read())
    except urllib.error.HTTPError as exc:
        if exc.code in {401, 403}:
            raise CollectorAuthError(f"{label} request failed with HTTP {exc.code}") from exc
        raise CollectorError(f"{label} request failed with HTTP {exc.code}") from exc


def _post_json(
    url: str,
    token: Optional[str],
    payload: dict[str, JsonValue],
    *,
    label: str = "worker response",
) -> dict[str, JsonValue]:
    body = json.dumps(payload, separators=(",", ":")).encode("utf-8")
    request = urllib.request.Request(
        url,
        data=body,
        headers={**_auth_headers(token), "Content-Type": "application/json"},
        method="POST",
    )
    try:
        with urllib.request.urlopen(request, timeout=HTTP_TIMEOUT_SECONDS) as response:
            response_body = _load_json_bytes(response.read())
    except urllib.error.HTTPError as exc:
        if exc.code in {401, 403}:
            raise CollectorAuthError(f"{label} request failed with HTTP {exc.code}") from exc
        raise CollectorError(f"{label} request failed with HTTP {exc.code}") from exc
    response_mapping = _json_mapping(response_body)
    if response_mapping is None:
        raise CollectorError(f"{label} for {urlsplit(url).path} must be a JSON object")
    return response_mapping


def _auth_headers(token: Optional[str]) -> dict[str, str]:
    headers = {
        "Accept": "application/json",
        "User-Agent": f"promptless-trace-collector/{COLLECTOR_VERSION}",
    }
    if token is not None:
        headers["Authorization"] = f"Bearer {token}"
    return headers


def _validate_upload_endpoint(value: str) -> None:
    parsed = urlsplit(value)
    if parsed.scheme not in {"http", "https"} or parsed.netloc == "":
        raise CollectorError("trace_collection.upload_endpoint must be an absolute HTTP(S) URL")
    if parsed.path != "/v0/traces/batches":
        raise CollectorError("trace_collection.upload_endpoint must use path /v0/traces/batches")
    if parsed.username is not None or parsed.password is not None or parsed.query or parsed.fragment:
        raise CollectorError("trace_collection.upload_endpoint must not include credentials, query, or fragment")
    if parsed.scheme == "http" and not _is_loopback_host(parsed.hostname):
        raise CollectorError("trace_collection.upload_endpoint must use HTTPS unless the host is loopback")


def _validate_http_url(value: str, field_name: str) -> SplitResult:
    parsed = urlsplit(value)
    if parsed.scheme not in {"http", "https"} or parsed.netloc == "":
        raise CollectorError(f"{field_name} must be an absolute HTTP(S) URL")
    if parsed.username is not None or parsed.password is not None or parsed.query or parsed.fragment:
        raise CollectorError(f"{field_name} must not include credentials, query, or fragment")
    return parsed


def _normalize_base_url(value: str, *, label: str = "worker base URL") -> str:
    stripped = value.strip().rstrip("/")
    parsed = _validate_http_url(stripped, label)
    if parsed.path not in {"", "/"}:
        raise CollectorError(f"{label} must not include a path")
    _validate_worker_transport(parsed, label)
    return stripped


def _validate_worker_transport(parsed: SplitResult, field_name: str) -> None:
    if parsed.scheme == "https":
        return
    if _test_url_overrides_enabled() and _is_loopback_parsed_url(parsed):
        return
    raise CollectorError(f"{field_name} must use HTTPS unless test URL overrides are enabled and the host is loopback")


def _test_url_overrides_enabled() -> bool:
    return os.environ.get(TEST_URL_OVERRIDE_ENV, "").strip().lower() in {"1", "true"} or os.environ.get(
        HOST_ENROLLMENT_TEST_URL_OVERRIDE_ENV, ""
    ).strip().lower() in {"1", "true"}


def _is_loopback_parsed_url(parsed: SplitResult) -> bool:
    return _is_loopback_host(parsed.hostname)


def _is_loopback_host(hostname: Optional[str]) -> bool:
    return hostname in {"127.0.0.1", "::1", "localhost"}


def _requires_newer_runtime(required: Optional[str], current: str) -> bool:
    if required is None:
        return False
    comparison = _compare_semver(current, required)
    if comparison is None:
        return required != current
    return comparison < 0


def _compare_semver(first: str, second: str) -> Optional[int]:
    first_match = SEMVER_RE.match(first)
    second_match = SEMVER_RE.match(second)
    if first_match is None or second_match is None:
        return None
    first_core = tuple(int(first_match.group(index)) for index in (1, 2, 3))
    second_core = tuple(int(second_match.group(index)) for index in (1, 2, 3))
    if first_core != second_core:
        return 1 if first_core > second_core else -1
    return _compare_prerelease(first_match.group(4), second_match.group(4))


def _compare_prerelease(first: Optional[str], second: Optional[str]) -> int:
    if first == second:
        return 0
    if first is None:
        return 1
    if second is None:
        return -1
    first_identifiers = first.split(".")
    second_identifiers = second.split(".")
    for first_part, second_part in zip(first_identifiers, second_identifiers):
        comparison = _compare_prerelease_identifier(first_part, second_part)
        if comparison != 0:
            return comparison
    if len(first_identifiers) == len(second_identifiers):
        return 0
    return 1 if len(first_identifiers) > len(second_identifiers) else -1


def _compare_prerelease_identifier(first: str, second: str) -> int:
    if first == second:
        return 0
    first_numeric = first.isdigit()
    second_numeric = second.isdigit()
    if first_numeric and second_numeric:
        first_number = int(first)
        second_number = int(second)
        return 1 if first_number > second_number else -1
    if first_numeric:
        return -1
    if second_numeric:
        return 1
    return 1 if first > second else -1


def _load_json_bytes(value: bytes) -> JsonValue:
    try:
        return _load_json_value(json.loads(value.decode("utf-8")))
    except json.JSONDecodeError as exc:
        raise CollectorError(f"worker returned invalid JSON: {exc.msg}") from exc


def _load_json_value(value: object) -> JsonValue:
    converted = _json_value(value)
    if converted is _INVALID_JSON:
        raise CollectorError("JSON contains unsupported values")
    return converted


def _json_mapping(value: object) -> Optional[dict[str, JsonValue]]:
    if not isinstance(value, dict):
        return None
    result: dict[str, JsonValue] = {}
    for key, child in value.items():
        if not isinstance(key, str):
            continue
        json_child = _json_value(child)
        if json_child is not _INVALID_JSON:
            result[key] = json_child
    return result


def _json_mapping_or_empty(value: Optional[JsonValue]) -> dict[str, JsonValue]:
    if isinstance(value, dict):
        return value
    return {}


def _json_value(value: object) -> Union[JsonValue, _InvalidJson]:
    if value is None or isinstance(value, (str, int, float, bool)):
        return value
    if isinstance(value, list):
        result: list[JsonValue] = []
        for item in value:
            child = _json_value(item)
            if child is not _INVALID_JSON:
                result.append(child)
        return result
    if isinstance(value, dict):
        result: dict[str, JsonValue] = {}
        for key, child in value.items():
            if not isinstance(key, str):
                continue
            json_child = _json_value(child)
            if json_child is not _INVALID_JSON:
                result[key] = json_child
        return result
    return _INVALID_JSON


def _string_mapping(value: Optional[JsonValue], field_name: str) -> dict[str, str]:
    if not isinstance(value, dict):
        raise CollectorError(f"{field_name} must be an object")
    result: dict[str, str] = {}
    for key, child in value.items():
        if isinstance(key, str) and isinstance(child, str):
            result[key] = child
    return result


def _host_value(value: Optional[JsonValue]) -> Optional[Host]:
    if value == "codex" or value == "claude":
        return value
    return None


def _string_value(value: Optional[JsonValue]) -> Optional[str]:
    if isinstance(value, str) and value != "":
        return value
    return None


def _int_value(value: Optional[JsonValue]) -> Optional[int]:
    if isinstance(value, bool):
        return None
    if isinstance(value, int):
        return value
    return None


def _bool_value(value: Optional[JsonValue], *, default: bool) -> bool:
    if isinstance(value, bool):
        return value
    return default


def _required_datetime_value(value: Optional[JsonValue], field_name: str) -> dt.datetime:
    text = _string_value(value)
    if text is None:
        raise CollectorError(f"{field_name} must be an ISO timestamp")
    try:
        parsed = dt.datetime.fromisoformat(text.replace("Z", "+00:00"))
    except ValueError as exc:
        raise CollectorError(f"{field_name} must be an ISO timestamp") from exc
    if parsed.tzinfo is None or parsed.utcoffset() is None:
        raise CollectorError(f"{field_name} must include a timezone")
    return parsed


def _optional_datetime_value(value: Optional[JsonValue], field_name: str) -> Optional[dt.datetime]:
    if value is None:
        return None
    return _required_datetime_value(value, field_name)


def _int_string_value(value: Optional[str], field_name: str) -> int:
    if value is None:
        raise CollectorError(f"{field_name} must be an integer")
    try:
        return int(value)
    except ValueError as exc:
        raise CollectorError(f"{field_name} must be an integer") from exc


def _optional_int_value(value: Optional[JsonValue]) -> Optional[int]:
    if isinstance(value, bool):
        return None
    if isinstance(value, int):
        return value
    return None


def _non_empty(value: Optional[str]) -> Optional[str]:
    if value is None or value.strip() == "":
        return None
    return value


def _path_hash(path: Path) -> str:
    return hashlib.sha256(str(path).encode("utf-8")).hexdigest()


def _self_sha256() -> str:
    return hashlib.sha256(Path(__file__).read_bytes()).hexdigest()


def _utc_now_iso() -> str:
    return dt.datetime.now(dt.timezone.utc).isoformat().replace("+00:00", "Z")


def _atomic_write_text(path: Path, body: str) -> None:
    temp_path: Optional[Path] = None
    try:
        with tempfile.NamedTemporaryFile(
            "w",
            encoding="utf-8",
            dir=path.parent,
            prefix=f".{path.name}.",
            delete=False,
        ) as temp_file:
            temp_path = Path(temp_file.name)
            temp_file.write(body)
            temp_file.flush()
            os.fsync(temp_file.fileno())
        os.replace(temp_path, path)
        _fsync_directory(path.parent)
    finally:
        if temp_path is not None and temp_path.exists():
            temp_path.unlink()


def _emit(
    payload: dict[str, JsonValue],
    *,
    quiet: bool,
    stream: Optional[object] = None,
    update_notice: Optional[str] = None,
) -> None:
    if quiet:
        return
    message = " ".join(text for text in (update_notice, _hook_user_message(payload)) if text is not None)
    diagnostic = dict(payload)
    if message:
        diagnostic["systemMessage"] = message
    diagnostic_stream = stream if stream is not None else sys.stderr
    print(json.dumps(_redact_json(diagnostic), sort_keys=True), file=diagnostic_stream)
    if message:
        print(json.dumps({"systemMessage": message}, sort_keys=True), file=sys.stdout)


def _hook_user_message(payload: dict[str, JsonValue]) -> Optional[str]:
    status = _string_value(payload.get("status"))
    if status == "setup_pending":
        return "Promptless trace collection is waiting for browser approval. Approve the opened tab, then restart the agent."
    if status == "blocked" and payload.get("reason") == "collector_upgrade_required":
        return "Promptless trace collection needs a newer Instruction Hub plugin before it can run."
    if status == "error":
        message = _string_value(payload.get("message"))
        if message is None:
            return "Promptless trace collection failed."
        return f"Promptless trace collection failed: {message}"
    return None


def _redact_json(value: JsonValue) -> JsonValue:
    if isinstance(value, str):
        return _redact_text(value)
    if isinstance(value, list):
        return [_redact_json(child) for child in value]
    if isinstance(value, dict):
        redacted: dict[str, JsonValue] = {}
        for key, child in value.items():
            if key.lower() in {"authorization", "device_code", "host_credential", "token"}:
                redacted[key] = "<redacted>"
            else:
                redacted[key] = _redact_json(child)
        return redacted
    return value


def _redact_text(value: str) -> str:
    redacted = re.sub(r"Bearer\s+[A-Za-z0-9._~+/=-]+", "Bearer <redacted>", value)
    redacted = re.sub(r"plihost_[A-Za-z0-9._~+/=-]+", "plihost_<redacted>", redacted)
    return re.sub(r"plihenroll_[A-Za-z0-9._~+/=-]+", "plihenroll_<redacted>", redacted)


class _InvalidJson:
    """Sentinel for values that cannot be represented as JSON."""


_INVALID_JSON = _InvalidJson()


if __name__ == "__main__":
    raise SystemExit(main())
