def main() -> int:
    """Run host enrollment and return a non-blocking hook exit code."""

    parser = argparse.ArgumentParser(description="Promptless host enrollment bootstrap")
    parser.add_argument("--host", choices=("auto", "codex", "claude"), default="auto")
    parser.add_argument("--quiet", action="store_true", help="Suppress hook status output")
    args = parser.parse_args()
    try:
        return _run(args.host, quiet=args.quiet)
    except (BootstrapError, OSError, ValueError, urllib.error.URLError) as exc:
        _emit({"status": "error", "message": _redact_text(str(exc))}, quiet=args.quiet, stream=sys.stderr)
        return 0


def _run(host_arg: str, *, quiet: bool) -> int:
    host = _resolve_host(host_arg)
    # Compute any plugin-update notice independent of the enrollment gate so every install (not
    # just enrolled hosts) learns when the Instruction Hub plugin version changed. Both Claude and
    # Codex render the SessionStart `systemMessage`. The new version is recorded only after the
    # hook output is emitted below, so a later failure re-announces it on the next healthy session.
    plugin_root = _plugin_root()
    metadata = _load_runtime_metadata(plugin_root, host)
    pending_update = _pending_plugin_update(metadata)
    update_notice = pending_update.notice if pending_update is not None else None
    exit_code = _run_host_enrollment(host, metadata, quiet=quiet, update_notice=update_notice)
    # Reached only when the host enrollment step returned without raising, i.e. the SessionStart
    # output (including any update notice) was emitted. A quiet run suppresses that output, so it
    # does not consume the one-time notice.
    if pending_update is not None and not quiet:
        _record_plugin_version_seen(pending_update)
    return exit_code


def _run_host_enrollment(host: Host, metadata: RuntimeMetadata, *, quiet: bool, update_notice: str | None) -> int:
    if not _bootstrap_auth_flow_enabled():
        _emit(
            {"status": "disabled", "reason": "pigs_fly_not_enabled", "host": host},
            quiet=quiet,
            update_notice=update_notice,
        )
        return 0

    worker_base_url = _worker_base_url()
    context = _enrollment_context(worker_base_url, metadata)
    credential = _obtain_host_credential(context)
    if credential is None:
        _emit(
            {"status": "setup_pending", "reason": "approval_pending", "host": host},
            quiet=quiet,
            update_notice=update_notice,
        )
        return 0

    policy_url = _worker_url(worker_base_url, f"/v0/host-enrollment/policy?{urlencode({'target': host})}")
    check_in_url = _worker_url(worker_base_url, "/v0/host-enrollment/check-ins")
    try:
        signed_policy = _get_json(policy_url, credential.value, label="policy response")
    except BootstrapAuthError:
        _forget_cached_host_credential(context)
        credential = _enroll_host_credential(context)
        if credential is None:
            _emit(
                {"status": "setup_pending", "reason": "approval_pending", "host": host},
                quiet=quiet,
                update_notice=update_notice,
            )
            return 0
        signed_policy = _get_json(policy_url, credential.value, label="policy response")
    policy = _validate_signed_policy(signed_policy, host)
    if _requires_newer_bootstrap(policy.required_bootstrap_version, BOOTSTRAP_VERSION):
        result = _blocked_result(
            host,
            policy,
            kind="bootstrap_upgrade_required",
            message="Worker policy requires a newer Promptless bootstrap runtime",
            details={
                "required_bootstrap_version": policy.required_bootstrap_version,
                "bootstrap_version": BOOTSTRAP_VERSION,
            },
        )
        _post_check_in(check_in_url, credential, host, metadata, policy, result)
        _emit(
            {"status": "blocked", "reason": "bootstrap_upgrade_required", "host": host},
            quiet=quiet,
            update_notice=update_notice,
        )
        return 0

    result = _configure_host(host, policy)
    _post_check_in(check_in_url, credential, host, metadata, policy, result)
    _emit(
        {"status": result.status, "host": host, "needs_restart": result.needs_restart},
        quiet=quiet,
        update_notice=update_notice,
    )
    return 0


@dataclass(frozen=True)
class PendingPluginUpdate:
    """The installed plugin version to record as seen for a host, with any one-time update notice."""

    target: str
    version: str
    notice: str | None


def _pending_plugin_update(metadata: RuntimeMetadata) -> PendingPluginUpdate | None:
    """Return the plugin version to record plus any one-time update notice, or None when there is nothing to do.

    The installed version comes from the plugin's managed-runtime manifest; the last-seen version is
    read from the host data dir (which survives plugin updates), keyed by host so a data dir shared
    between Claude and Codex tracks each separately. This is read-only and best-effort: a missing,
    unwritable, or corrupt data dir must never turn an otherwise healthy or gate-disabled SessionStart
    into an error, so state I/O and parse failures yield no notice. The notice is None on a first
    install (nothing seen yet); the version is still returned so the caller can record it.
    """

    current_version = metadata.plugin_version
    if current_version == "unknown":
        return None
    try:
        state_path = _state_path()
        with _state_file_lock(state_path):
            seen_versions = _json_mapping_or_empty(_load_state(state_path).get("last_seen_plugin_versions"))
        last_seen_version = _string_value(seen_versions.get(metadata.target))
    except (OSError, BootstrapError):
        return None
    if last_seen_version == current_version:
        return None
    notice = (
        None
        if last_seen_version is None
        else f"Promptless Instruction Hub updated to v{current_version} (was v{last_seen_version})."
    )
    return PendingPluginUpdate(target=metadata.target, version=current_version, notice=notice)


def _record_plugin_version_seen(pending: PendingPluginUpdate) -> None:
    """Persist the installed plugin version as seen for the host, preserving other state.

    Called only after the SessionStart output (including any update notice) has been emitted, so a
    failure before output leaves the prior version and re-announces next time. Best-effort: state I/O
    failures are swallowed so recording never breaks a session. Re-reads state under the lock so a
    credential written by the enrollment step in the same run is preserved.
    """

    try:
        state_path = _state_path()
        with _state_file_lock(state_path):
            state = _load_state(state_path)
            seen_versions = _json_mapping_or_empty(state.get("last_seen_plugin_versions"))
            seen_versions[pending.target] = pending.version
            state["last_seen_plugin_versions"] = seen_versions
            _write_state(state_path, state)
    except (OSError, BootstrapError):
        return


def _resolve_host(host_arg: str) -> Host:
    if host_arg == "codex" or host_arg == "claude":
        return host_arg
    if os.environ.get("CLAUDE_PLUGIN_ROOT"):
        return "claude"
    return "codex"


def _bootstrap_auth_flow_enabled() -> bool:
    """Return whether the end-user device has enabled bootstrap auth testing."""

    return os.environ.get(BOOTSTRAP_AUTH_FLAG_ENV) == "True"


def _plugin_root() -> Path | None:
    raw_root = os.environ.get("PLUGIN_ROOT") or os.environ.get("CLAUDE_PLUGIN_ROOT")
    if raw_root is None or raw_root.strip() == "":
        return None
    return Path(raw_root).expanduser()


def _worker_base_url() -> str:
    return _normalize_base_url(os.environ.get("PROMPTLESS_WORKER_BASE_URL") or DEFAULT_WORKER_BASE_URL)


def _enrollment_context(worker_base_url: str, metadata: RuntimeMetadata) -> EnrollmentContext:
    state_path = _state_path()
    with _state_file_lock(state_path):
        state = _load_state(state_path)
        host_instance_id = _host_instance_id(state)
        if state.get("host_instance_id") != host_instance_id:
            state["host_instance_id"] = host_instance_id
            _write_state(state_path, state)
    return EnrollmentContext(
        worker_base_url=worker_base_url,
        metadata=metadata,
        host_instance_id=host_instance_id,
        host_label=_host_label(),
        host_platform=_host_platform(),
    )


def _state_path() -> Path:
    for raw_dir in (os.environ.get("PLUGIN_DATA"), os.environ.get("CLAUDE_PLUGIN_DATA")):
        if raw_dir:
            return Path(raw_dir).expanduser() / STATE_FILE_NAME
    return Path.home() / ".promptless/instruction-hub" / STATE_FILE_NAME


def _load_state(path: Path) -> dict[str, JsonValue]:
    if not path.exists():
        return {}
    try:
        value = json.loads(path.read_text())
    except json.JSONDecodeError as exc:
        raise BootstrapError(f"host enrollment state is invalid JSON at {path}: {exc.msg}") from exc
    if not isinstance(value, dict):
        raise BootstrapError(f"host enrollment state must be a JSON object at {path}")
    return _json_object(value)


def _write_state(path: Path, state: dict[str, JsonValue]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    body = json.dumps(state, indent=2, sort_keys=True) + "\n"
    _atomic_write_text(path, body)
    try:
        path.chmod(0o600)
    except OSError:
        pass


@contextmanager
def _state_file_lock(path: Path) -> Iterator[None]:
    lock_path = path.with_name(f"{path.name}.lock")
    lock_path.parent.mkdir(parents=True, exist_ok=True)
    with lock_path.open("a+b") as lock_file:
        _lock_state_file(lock_file)
        try:
            yield
        finally:
            _unlock_state_file(lock_file)


def _lock_state_file(lock_file: BinaryIO) -> None:
    if os.name == "nt":
        _ensure_windows_lock_byte(lock_file)
        msvcrt.locking(lock_file.fileno(), msvcrt.LK_LOCK, 1)
        return
    fcntl.flock(lock_file.fileno(), fcntl.LOCK_EX)


def _unlock_state_file(lock_file: BinaryIO) -> None:
    if os.name == "nt":
        lock_file.seek(0)
        msvcrt.locking(lock_file.fileno(), msvcrt.LK_UNLCK, 1)
        return
    fcntl.flock(lock_file.fileno(), fcntl.LOCK_UN)


def _ensure_windows_lock_byte(lock_file: BinaryIO) -> None:
    lock_file.seek(0)
    if lock_file.read(1) == b"":
        lock_file.seek(0)
        lock_file.write(b"\0")
        lock_file.flush()
    lock_file.seek(0)


def _host_instance_id(state: dict[str, JsonValue]) -> str:
    existing = _non_empty(_string_value(state.get("host_instance_id")))
    if existing is not None:
        return existing
    return f"host-{uuid.uuid4().hex}"


def _host_label() -> str:
    username = _non_empty(getpass.getuser()) or "unknown-user"
    node = _non_empty(platform.node()) or "unknown-host"
    return _truncate(f"{username}@{node}", 240)


def _host_platform() -> str:
    return _truncate(platform.platform(), 120)


def _truncate(value: str, max_length: int) -> str:
    if len(value) <= max_length:
        return value
    return value[:max_length]


def _obtain_host_credential(context: EnrollmentContext) -> HostCredential | None:
    credential = _cached_host_credential(context)
    if credential is not None:
        return credential
    return _enroll_host_credential(context)


def _cached_host_credential(context: EnrollmentContext) -> HostCredential | None:
    state_path = _state_path()
    state = _load_state(state_path)
    credentials = _json_mapping_or_empty(state.get("credentials"))
    cached_credential = _json_mapping_or_empty(credentials.get(_credential_cache_key(context)))
    credential_value = _string_value(cached_credential.get("value"))
    credential_id = _string_value(cached_credential.get("credential_id"))
    deployment_instance_id = _string_value(cached_credential.get("deployment_instance_id"))
    credential = (
        HostCredential(
            value=credential_value,
            credential_id=credential_id,
            deployment_instance_id=deployment_instance_id,
        )
        if credential_value
        else None
    )
    return credential


def _forget_cached_host_credential(context: EnrollmentContext) -> None:
    state_path = _state_path()
    with _state_file_lock(state_path):
        state = _load_state(state_path)
        credentials = _json_mapping_or_empty(state.get("credentials"))
        key = _credential_cache_key(context)
        if key in credentials:
            del credentials[key]
            state["credentials"] = credentials
            _write_state(state_path, state)


def _enroll_host_credential(context: EnrollmentContext) -> HostCredential | None:
    state_path = _state_path()
    session = _load_pending_enrollment_session(context, state_path)
    if session is None:
        created_session = _create_enrollment_session(context)
        session, stored_new_session = _store_pending_enrollment(context, state_path, created_session)
        if stored_new_session:
            _open_approval_url(session.approval_url)
    credential = _poll_enrollment_session(context, session)
    if credential is None:
        return None
    _store_host_credential(context, state_path, credential)
    return credential


def _load_pending_enrollment_session(context: EnrollmentContext, state_path: Path) -> EnrollmentSession | None:
    with _state_file_lock(state_path):
        return _pending_enrollment_session(context, _load_state(state_path))


def _pending_enrollment_session(context: EnrollmentContext, state: dict[str, JsonValue]) -> EnrollmentSession | None:
    pending_enrollments = _json_mapping_or_empty(state.get("pending_enrollments"))
    session_value = _json_mapping_or_empty(pending_enrollments.get(_credential_cache_key(context)))
    if not session_value:
        return None
    expires_at = _optional_datetime_value(session_value.get("expires_at"), "pending enrollment expires_at")
    if expires_at is None or expires_at <= dt.datetime.now(dt.timezone.utc):
        return None
    session_id = _string_value(session_value.get("session_id"))
    device_code = _string_value(session_value.get("device_code"))
    approval_url = _string_value(session_value.get("approval_url"))
    poll_interval_seconds = _optional_int_value(session_value.get("poll_interval_seconds"))
    deployment_instance_id = _string_value(session_value.get("deployment_instance_id"))
    if (
        session_id is None
        or deployment_instance_id is None
        or device_code is None
        or approval_url is None
        or poll_interval_seconds is None
    ):
        return None
    return EnrollmentSession(
        session_id=session_id,
        deployment_instance_id=deployment_instance_id,
        device_code=device_code,
        approval_url=approval_url,
        expires_at=expires_at,
        poll_interval_seconds=poll_interval_seconds,
    )


def _create_enrollment_session(context: EnrollmentContext) -> EnrollmentSession:
    payload: dict[str, JsonValue] = {
        "target": context.metadata.target,
        "plugin_id": context.metadata.plugin_id,
        "plugin_version": context.metadata.plugin_version,
        "package_id": context.metadata.package_id,
        "bootstrap_version": context.metadata.bootstrap_version,
        "toolchain_version": context.metadata.toolchain_version,
        "host_instance_id": context.host_instance_id,
        "host_label": context.host_label,
        "host_platform": context.host_platform,
    }
    response = _post_json_response(
        _worker_url(context.worker_base_url, "/v0/host-enrollment/sessions"),
        None,
        payload,
        label="host enrollment session response",
    )
    session_id = _string_value(response.get("session_id"))
    deployment_instance_id = _string_value(response.get("deployment_instance_id"))
    device_code = _string_value(response.get("device_code"))
    approval_url = _string_value(response.get("approval_url"))
    expires_at = _datetime_value(response.get("expires_at"), "host enrollment session expires_at")
    poll_interval_seconds = _int_value(response.get("poll_interval_seconds"), "host enrollment poll interval")
    if session_id is None or deployment_instance_id is None or device_code is None or approval_url is None:
        raise BootstrapError("host enrollment session response missing required fields")
    if poll_interval_seconds < 1 or poll_interval_seconds > 30:
        raise BootstrapError("host enrollment poll interval must be between 1 and 30 seconds")
    return EnrollmentSession(
        session_id=session_id,
        deployment_instance_id=deployment_instance_id,
        device_code=device_code,
        approval_url=approval_url,
        expires_at=expires_at,
        poll_interval_seconds=poll_interval_seconds,
    )


def _store_pending_enrollment(
    context: EnrollmentContext,
    state_path: Path,
    session: EnrollmentSession,
) -> tuple[EnrollmentSession, bool]:
    with _state_file_lock(state_path):
        state = _load_state(state_path)
        existing_session = _pending_enrollment_session(context, state)
        if existing_session is not None:
            return existing_session, False
        pending_enrollments = _json_mapping_or_empty(state.get("pending_enrollments"))
        pending_enrollments[_credential_cache_key(context)] = {
            "session_id": session.session_id,
            "deployment_instance_id": session.deployment_instance_id,
            "device_code": session.device_code,
            "approval_url": session.approval_url,
            "expires_at": session.expires_at.isoformat(),
            "poll_interval_seconds": session.poll_interval_seconds,
        }
        state["pending_enrollments"] = pending_enrollments
        _write_state(state_path, state)
        return session, True


def _poll_enrollment_session(context: EnrollmentContext, session: EnrollmentSession) -> HostCredential | None:
    deadline = time.monotonic() + ENROLLMENT_POLL_DEADLINE_SECONDS
    while True:
        response = _post_json_response(
            _worker_url(context.worker_base_url, f"/v0/host-enrollment/sessions/{session.session_id}/poll"),
            None,
            {"device_code": session.device_code},
            label="host enrollment poll response",
        )
        status = _string_value(response.get("status"))
        if status == "approved":
            host_credential = _string_value(response.get("host_credential"))
            if host_credential is None:
                raise BootstrapError("approved host enrollment poll response missing host_credential")
            return HostCredential(
                value=host_credential,
                credential_id=_string_value(response.get("credential_id")),
                deployment_instance_id=session.deployment_instance_id,
            )
        if status in {"expired", "consumed"}:
            _forget_pending_enrollment(context)
            return None
        if status != "pending":
            raise BootstrapError("host enrollment poll response has invalid status")
        remaining_seconds = deadline - time.monotonic()
        if remaining_seconds <= 0:
            return None
        time.sleep(min(float(session.poll_interval_seconds), remaining_seconds))


def _store_host_credential(
    context: EnrollmentContext,
    state_path: Path,
    credential: HostCredential,
) -> None:
    with _state_file_lock(state_path):
        state = _load_state(state_path)
        credentials = _json_mapping_or_empty(state.get("credentials"))
        credentials[_credential_cache_key(context)] = {
            "value": credential.value,
            "credential_id": credential.credential_id,
            "worker_base_url": context.worker_base_url,
            "deployment_instance_id": credential.deployment_instance_id,
            "target": context.metadata.target,
            "plugin_id": context.metadata.plugin_id,
            "package_id": context.metadata.package_id,
            "updated_at": dt.datetime.now(dt.timezone.utc).isoformat(),
        }
        state["credentials"] = credentials
        pending_enrollments = _json_mapping_or_empty(state.get("pending_enrollments"))
        pending_enrollments.pop(_credential_cache_key(context), None)
        state["pending_enrollments"] = pending_enrollments
        _write_state(state_path, state)


def _forget_pending_enrollment(context: EnrollmentContext) -> None:
    state_path = _state_path()
    with _state_file_lock(state_path):
        state = _load_state(state_path)
        pending_enrollments = _json_mapping_or_empty(state.get("pending_enrollments"))
        if pending_enrollments.pop(_credential_cache_key(context), None) is not None:
            state["pending_enrollments"] = pending_enrollments
            _write_state(state_path, state)


def _credential_cache_key(context: EnrollmentContext) -> str:
    cache_material = {
        "package_id": context.metadata.package_id,
        "plugin_id": context.metadata.plugin_id,
        "target": context.metadata.target,
        "worker_base_url": context.worker_base_url,
    }
    return hashlib.sha256(json.dumps(cache_material, sort_keys=True).encode()).hexdigest()


def _open_approval_url(approval_url: str) -> None:
    if os.environ.get(OPEN_BROWSER_ENV) == "0":
        return
    try:
        webbrowser.open(approval_url, new=2, autoraise=True)
    except webbrowser.Error:
        return


def _worker_url(worker_base_url: str, path: str) -> str:
    return f"{worker_base_url}{path}"


def _load_runtime_metadata(plugin_root: Path | None, host: Host) -> RuntimeMetadata:
    defaults = RuntimeMetadata(
        bootstrap_version=BOOTSTRAP_VERSION,
        bootstrap_channel=BOOTSTRAP_CHANNEL,
        bootstrap_sha256=_self_sha256(),
        toolchain_version="unknown",
        plugin_id="unknown",
        plugin_version="unknown",
        package_id="unknown",
        target=host,
    )
    if plugin_root is None:
        return defaults
    manifest_path = plugin_root / MANAGED_RUNTIME_MANIFEST
    if not manifest_path.exists():
        return defaults
    try:
        manifest = json.loads(manifest_path.read_text())
    except (OSError, json.JSONDecodeError):
        return defaults
    if not isinstance(manifest, dict):
        return defaults
    runtimes = manifest.get("managed_runtimes")
    if not isinstance(runtimes, list):
        return defaults
    for runtime in runtimes:
        if not isinstance(runtime, dict):
            continue
        if runtime.get("id") != MANAGED_RUNTIME_ID or runtime.get("status") != "included":
            continue
        return RuntimeMetadata(
            bootstrap_version=BOOTSTRAP_VERSION,
            bootstrap_channel=BOOTSTRAP_CHANNEL,
            bootstrap_sha256=_self_sha256(),
            toolchain_version=_string_value(runtime.get("toolchain_version")) or "unknown",
            plugin_id=_string_value(runtime.get("plugin_id")) or "unknown",
            plugin_version=_string_value(runtime.get("plugin_version")) or "unknown",
            package_id=_string_value(runtime.get("package_id")) or "unknown",
            target=_runtime_target(runtime.get("target"), host),
        )
    return defaults


def _get_json(url: str, token: str | None, *, label: str) -> dict[str, JsonValue]:
    headers = _auth_headers(token)
    request = urllib.request.Request(url, headers=headers, method="GET")
    try:
        with urllib.request.urlopen(request, timeout=HTTP_TIMEOUT_SECONDS) as response:
            body = response.read()
    except urllib.error.HTTPError as exc:
        if exc.code in {401, 403}:
            raise BootstrapAuthError(f"{label} request failed with HTTP {exc.code}") from exc
        raise BootstrapError(f"{label} request failed with HTTP {exc.code}") from exc
    return _decode_json_object(body, label)


def _post_check_in(
    url: str,
    credential: HostCredential,
    host: Host,
    metadata: RuntimeMetadata,
    policy: HostPolicy,
    result: ConfigResult,
) -> None:
    payload = _check_in_payload(host, metadata, policy, result)
    response_payload = _post_json_response(url, credential.value, payload, label="check-in response")
    if response_payload.get("accepted") is not True:
        raise BootstrapError("check-in response was not accepted")
    response_policy_version = response_payload.get("policy_version")
    if type(response_policy_version) is not int or response_policy_version != policy.policy_version:
        raise BootstrapError("check-in response policy version did not match the applied policy")


def _post_json_response(
    url: str,
    token: str | None,
    payload: dict[str, JsonValue],
    *,
    label: str,
) -> dict[str, JsonValue]:
    body = json.dumps(payload, sort_keys=True).encode()
    request = urllib.request.Request(
        url,
        data=body,
        headers={**_auth_headers(token), "Content-Type": "application/json"},
        method="POST",
    )
    try:
        with urllib.request.urlopen(request, timeout=HTTP_TIMEOUT_SECONDS) as response:
            return _decode_json_object(response.read(), label)
    except urllib.error.HTTPError as exc:
        if exc.code in {401, 403}:
            raise BootstrapAuthError(f"{label} request failed with HTTP {exc.code}") from exc
        raise BootstrapError(f"{label} request failed with HTTP {exc.code}") from exc


def _auth_headers(token: str | None) -> dict[str, str]:
    if token is None:
        return {}
    return {"Authorization": f"Bearer {token}"}


def _check_in_payload(
    host: Host,
    metadata: RuntimeMetadata,
    policy: HostPolicy,
    result: ConfigResult,
) -> dict[str, JsonValue]:
    return {
        "host": host,
        "plugin_version": metadata.plugin_version,
        "policy_version": policy.policy_version,
        "status": result.status,
        "needs_restart": result.needs_restart,
        "effective_config": result.effective_config,
        "drift_reports": [_redact_json(report) for report in result.drift_reports],
        "checked_at": dt.datetime.now(dt.timezone.utc).isoformat(),
        "bootstrap_version": metadata.bootstrap_version,
    }


def _validate_signed_policy(payload: dict[str, JsonValue], host: Host) -> HostPolicy:
    policy_value = payload.get("policy")
    if not isinstance(policy_value, dict):
        raise BootstrapError("policy response missing policy object")
    signature = _string_value(payload.get("signature"))
    if signature is None or re.fullmatch(r"[A-Za-z0-9._-]+:.+", signature) is None:
        raise BootstrapError("policy response has invalid signature shape")
    # The dogfood endpoint relies on HTTPS transport authentication; this bootstrap only
    # shape-checks the hosted policy signature. Before broader customer rollout, hosted
    # policies should use asymmetric signatures verified here by the static native binary.
    schema_version = _int_value(policy_value.get("schema_version"), "policy.schema_version")
    if schema_version != 1:
        raise BootstrapError("policy.schema_version must be 1")
    expires_at = _datetime_value(policy_value.get("expires_at"), "policy.expires_at")
    if expires_at <= dt.datetime.now(dt.timezone.utc):
        raise BootstrapError("policy has expired")
    policy_version = _int_value(policy_value.get("policy_version"), "policy.policy_version")
    enabled_hosts = policy_value.get("enabled_hosts")
    if not isinstance(enabled_hosts, list) or host not in enabled_hosts:
        raise BootstrapError(f"policy does not enable {host}")
    collector = _validate_collector(policy_value.get("collector"))
    capture_policy = _validate_capture_policy(policy_value.get("capture_policy"))
    permissions = policy_value.get("plugin_permissions")
    if not isinstance(permissions, dict) or permissions.get("write_user_config") is not True:
        raise BootstrapError("policy does not allow user config writes")
    required_bootstrap_version = _string_value(policy_value.get("required_bootstrap_version"))
    return HostPolicy(
        policy_version=policy_version,
        collector=collector,
        capture_policy=capture_policy,
        required_bootstrap_version=required_bootstrap_version,
    )


def _validate_collector(value: JsonValue | None) -> CollectorPolicy:
    if not isinstance(value, dict):
        raise BootstrapError("policy.collector must be an object")
    logs_endpoint = _validate_otlp_http_endpoint(value.get("otlp_http_logs_endpoint"), "collector logs", "/v1/logs")
    traces_endpoint = _validate_otlp_http_endpoint(
        value.get("otlp_http_traces_endpoint"), "collector traces", "/v1/traces"
    )
    metrics_endpoint = _validate_otlp_http_endpoint(
        value.get("otlp_http_metrics_endpoint"),
        "collector metrics",
        "/v1/metrics",
    )
    grpc_endpoint = _string_value(value.get("otlp_grpc_endpoint"))
    if grpc_endpoint is not None:
        _validate_http_url(grpc_endpoint, "collector grpc")
    headers = value.get("headers")
    if not isinstance(headers, dict) or not headers:
        raise BootstrapError("policy.collector.headers must contain at least one header")
    header_map: dict[str, str] = {}
    for raw_name, raw_header_value in headers.items():
        name = _string_value(raw_name)
        header_value = _string_value(raw_header_value)
        if name is None or header_value is None or not name.strip() or not header_value.strip():
            raise BootstrapError("collector headers must be non-empty strings")
        if HEADER_NAME_RE.fullmatch(name) is None:
            raise BootstrapError("collector header names must be HTTP tokens")
        if any(char in name + header_value for char in ("\r", "\n", ",")):
            raise BootstrapError("collector headers must not contain newline or comma characters")
        header_map[name] = header_value
    return CollectorPolicy(
        logs_endpoint=logs_endpoint,
        traces_endpoint=traces_endpoint,
        metrics_endpoint=metrics_endpoint,
        grpc_endpoint=grpc_endpoint,
        headers=header_map,
    )


def _validate_capture_policy(value: JsonValue | None) -> dict[str, str]:
    if not isinstance(value, dict):
        raise BootstrapError("policy.capture_policy must be an object")
    capture_policy: dict[str, str] = {}
    for key in ("user_prompts", "tool_inputs", "tool_outputs", "raw_api_bodies"):
        policy_value = _string_value(value.get(key))
        if policy_value is None:
            raise BootstrapError(f"policy.capture_policy.{key} must be a string")
        if policy_value not in CAPTURE_POLICY_VALUES:
            raise BootstrapError(f"policy.capture_policy.{key} must be one of {sorted(CAPTURE_POLICY_VALUES)}")
        capture_policy[key] = policy_value
    return capture_policy


def _configure_host(host: Host, policy: HostPolicy) -> ConfigResult:
    if host == "codex":
        return _configure_codex(policy)
    return _configure_claude(policy)


def _configure_codex(policy: HostPolicy) -> ConfigResult:
    config_path = Path(os.environ.get("CODEX_HOME", Path.home() / ".codex")).expanduser() / "config.toml"
    config_path.parent.mkdir(parents=True, exist_ok=True)
    existing = config_path.read_text() if config_path.exists() else ""
    managed_block = _codex_managed_block(policy)
    unsupported_capture_fields = _unsupported_codex_capture_fields(policy)
    if unsupported_capture_fields:
        return _blocked_result(
            "codex",
            policy,
            kind="manual_config_required",
            message="Codex policy requires capture controls this bootstrap cannot enforce",
            details={"path": str(config_path), "capture_policy_keys": unsupported_capture_fields},
        )
    unmanaged_source = _without_managed_block(existing)
    if _has_unmanaged_codex_otel_config(unmanaged_source):
        return _blocked_result(
            "codex",
            policy,
            kind="manual_config_required",
            message="Existing unmanaged Codex otel config was left unchanged",
            details={"path": str(config_path)},
        )
    updated = _replace_managed_block(existing, managed_block)
    changed = updated != existing
    if changed:
        _write_with_backup(config_path, updated)
    return ConfigResult(
        status="needs_restart" if changed else "configured",
        needs_restart=changed,
        effective_config=_effective_config("codex", policy, configured=True, managed_config_detected=True),
        drift_reports=_updated_config_reports("codex", config_path, changed),
    )


def _codex_managed_block(policy: HostPolicy) -> str:
    # Codex reads user-level ~/.codex/config.toml, or CODEX_HOME/config.toml, for OTel routing keys.
    # https://developers.openai.com/codex/config-advanced
    # https://developers.openai.com/codex/config-reference
    headers = _toml_inline_headers(policy.collector.headers)
    return "\n".join(
        [
            MANAGED_BEGIN,
            "[otel]",
            'environment = "prod"',
            f"log_user_prompt = {_toml_bool(_capture_enabled(policy, 'user_prompts'))}",
            "",
            "[otel.exporter.otlp-http]",
            f"endpoint = {_toml_string(policy.collector.logs_endpoint)}",
            'protocol = "binary"',
            f"headers = {headers}",
            "",
            "[otel.trace_exporter.otlp-http]",
            f"endpoint = {_toml_string(policy.collector.traces_endpoint)}",
            'protocol = "binary"',
            f"headers = {headers}",
            MANAGED_END,
            "",
        ]
    )


def _has_unmanaged_codex_otel_config(existing: str) -> bool:
    return (
        re.search(r"(?m)^\s*\[otel(?:\]|\.)", existing) is not None
        or re.search(
            r"(?m)^\s*otel(?:\s*=|\.)",
            existing,
        )
        is not None
    )


def _without_managed_block(existing: str) -> str:
    if existing.count(MANAGED_BEGIN) != 1 or existing.count(MANAGED_END) != 1:
        return existing
    return _managed_block_pattern().sub("", existing, count=1)


def _managed_block_pattern() -> re.Pattern[str]:
    return re.compile(re.escape(MANAGED_BEGIN) + r".*?" + re.escape(MANAGED_END) + r"\n?", re.DOTALL)


def _configure_claude(policy: HostPolicy) -> ConfigResult:
    settings_path = Path(os.environ.get("CLAUDE_CONFIG_DIR", Path.home() / ".claude")).expanduser() / "settings.json"
    settings_path.parent.mkdir(parents=True, exist_ok=True)
    settings = _read_settings(settings_path)
    env = settings.setdefault("env", {})
    if not isinstance(env, dict):
        return _blocked_result(
            "claude",
            policy,
            kind="manual_config_required",
            message="Claude settings env is not an object",
            details={"path": str(settings_path)},
        )
    desired_env = _claude_env(policy)
    unmanaged_conflicts = _unmanaged_claude_env_conflicts(env, desired_env)
    if unmanaged_conflicts:
        return _blocked_result(
            "claude",
            policy,
            kind="manual_config_required",
            message="Existing unmanaged Claude telemetry env was left unchanged",
            details={"path": str(settings_path), "env_keys": unmanaged_conflicts},
        )
    current_settings = json.dumps(settings, sort_keys=True)
    env.update(desired_env)
    changed = json.dumps(settings, sort_keys=True) != current_settings
    updated_settings = json.dumps(settings, indent=2, sort_keys=True) + "\n"
    if changed:
        _write_with_backup(settings_path, updated_settings)
    return ConfigResult(
        status="needs_restart" if changed else "configured",
        needs_restart=changed,
        effective_config=_effective_config("claude", policy, configured=True, managed_config_detected=True),
        drift_reports=_updated_config_reports("claude", settings_path, changed),
    )


def _read_settings(settings_path: Path) -> dict[str, JsonValue]:
    if not settings_path.exists():
        return {}
    try:
        value = json.loads(settings_path.read_text())
    except json.JSONDecodeError as exc:
        raise BootstrapError(f"Claude settings are invalid JSON at {settings_path}: {exc.msg}") from exc
    if not isinstance(value, dict):
        raise BootstrapError(f"Claude settings must be a JSON object at {settings_path}")
    return value


def _claude_env(policy: HostPolicy) -> dict[str, str]:
    # Claude Code supports OTel through settings.json env keys.
    # https://docs.anthropic.com/en/docs/claude-code/monitoring-usage
    return {
        CLAUDE_MANAGED_ENV_MARKER: "1",
        "CLAUDE_CODE_ENHANCED_TELEMETRY_BETA": "1",
        "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
        "OTEL_LOGS_EXPORTER": "otlp",
        "OTEL_METRICS_EXPORTER": "otlp",
        "OTEL_TRACES_EXPORTER": "otlp",
        "OTEL_EXPORTER_OTLP_PROTOCOL": "http/protobuf",
        "OTEL_EXPORTER_OTLP_LOGS_ENDPOINT": policy.collector.logs_endpoint,
        "OTEL_EXPORTER_OTLP_TRACES_ENDPOINT": policy.collector.traces_endpoint,
        "OTEL_EXPORTER_OTLP_METRICS_ENDPOINT": policy.collector.metrics_endpoint,
        "OTEL_EXPORTER_OTLP_HEADERS": _otel_headers(policy.collector.headers),
        "OTEL_LOG_USER_PROMPTS": _env_bool(_capture_enabled(policy, "user_prompts")),
        # Claude Code falls back to OTEL_LOG_USER_PROMPTS for assistant responses
        # when unset. Keep responses off until policy exposes an explicit field.
        "OTEL_LOG_ASSISTANT_RESPONSES": "0",
        "OTEL_LOG_TOOL_DETAILS": _env_bool(_capture_enabled(policy, "tool_inputs")),
        "OTEL_LOG_TOOL_CONTENT": _env_bool(_capture_enabled(policy, "tool_outputs")),
        "OTEL_LOG_RAW_API_BODIES": _env_bool(_capture_enabled(policy, "raw_api_bodies")),
    }


def _unmanaged_claude_env_conflicts(env: dict[object, object], desired_env: dict[str, str]) -> list[str]:
    if _string_value(env.get(CLAUDE_MANAGED_ENV_MARKER)) == "1":
        return []
    conflicts: list[str] = []
    for key in sorted(desired_env):
        if key == CLAUDE_MANAGED_ENV_MARKER:
            continue
        existing = env.get(key)
        if existing is None:
            continue
        if isinstance(existing, str) and existing == "":
            continue
        conflicts.append(key)
    return conflicts


def _effective_config(
    host: Host,
    policy: HostPolicy,
    *,
    configured: bool,
    managed_config_detected: bool,
) -> dict[str, JsonValue]:
    effective_config: dict[str, JsonValue] = {
        "host": host,
        "configured": configured,
        "collector_logs_endpoint": policy.collector.logs_endpoint if configured else None,
        "collector_traces_endpoint": policy.collector.traces_endpoint if configured else None,
        "collector_metrics_endpoint": _effective_metrics_endpoint(host, policy, configured=configured),
        "user_prompts_enabled": _capture_enabled(policy, "user_prompts") if configured else None,
        "tool_inputs_enabled": _capture_enabled(policy, "tool_inputs") if configured else None,
        "tool_outputs_enabled": _capture_enabled(policy, "tool_outputs") if configured else None,
        "raw_api_bodies_enabled": _capture_enabled(policy, "raw_api_bodies") if configured else None,
        "managed_config_detected": managed_config_detected,
    }
    effective_config["config_hash"] = hashlib.sha256(json.dumps(effective_config, sort_keys=True).encode()).hexdigest()
    return effective_config


def _blocked_result(
    host: Host,
    policy: HostPolicy,
    *,
    kind: str,
    message: str,
    details: dict[str, JsonValue],
) -> ConfigResult:
    return ConfigResult(
        status="blocked",
        needs_restart=False,
        effective_config=_effective_config(host, policy, configured=False, managed_config_detected=False),
        drift_reports=[
            {
                "kind": kind,
                "message": message,
                "repaired": False,
                "details": details,
            }
        ],
    )


def _effective_metrics_endpoint(host: Host, policy: HostPolicy, *, configured: bool) -> str | None:
    if not configured or host == "codex":
        return None
    return policy.collector.metrics_endpoint


def _unsupported_codex_capture_fields(policy: HostPolicy) -> list[str]:
    unsupported_fields: list[str] = []
    for key in ("tool_inputs", "tool_outputs"):
        if policy.capture_policy.get(key) != "full_local_default":
            unsupported_fields.append(key)
    if policy.capture_policy.get("raw_api_bodies") != "disabled":
        unsupported_fields.append("raw_api_bodies")
    return unsupported_fields


def _updated_config_reports(host: Host, path: Path, changed: bool) -> list[dict[str, JsonValue]]:
    if not changed:
        return []
    return [
        {
            "kind": "repaired_user_config",
            "message": f"Updated user-level {host} telemetry config",
            "repaired": True,
            "details": {"path": str(path)},
        }
    ]


def _replace_managed_block(existing: str, managed_block: str) -> str:
    if MANAGED_BEGIN in existing and MANAGED_END in existing:
        return _managed_block_pattern().sub(managed_block, existing, count=1)
    prefix = existing.rstrip()
    if not prefix:
        return managed_block
    return prefix + "\n\n" + managed_block


def _write_with_backup(path: Path, contents: str) -> None:
    if path.exists():
        timestamp = dt.datetime.now(dt.timezone.utc).strftime("%Y%m%d%H%M%S%f")
        shutil.copy2(path, path.with_name(f"{path.name}.{timestamp}.bak"))
    _atomic_write_text(path, contents)


def _atomic_write_text(path: Path, contents: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    file_descriptor, temporary_name = tempfile.mkstemp(prefix=f".{path.name}.", suffix=".tmp", dir=path.parent)
    temporary_path = Path(temporary_name)
    try:
        with os.fdopen(file_descriptor, "w", encoding="utf-8") as handle:
            handle.write(contents)
            handle.flush()
            os.fsync(handle.fileno())
        os.replace(temporary_path, path)
        _fsync_directory(path.parent)
    finally:
        try:
            temporary_path.unlink()
        except FileNotFoundError:
            pass


def _fsync_directory(path: Path) -> None:
    if os.name != "posix":
        return
    directory_descriptor = os.open(path, os.O_RDONLY)
    try:
        os.fsync(directory_descriptor)
    finally:
        os.close(directory_descriptor)


def _requires_newer_bootstrap(required: str | None, current: str) -> bool:
    if required is None:
        return False
    required_tuple = _semver_tuple(required)
    current_tuple = _semver_tuple(current)
    if required_tuple is None or current_tuple is None:
        return required != current
    return current_tuple < required_tuple


def _semver_tuple(value: str) -> tuple[int, int, int] | None:
    match = re.match(r"^(0|[1-9]\d*)\.(0|[1-9]\d*)\.(0|[1-9]\d*)", value)
    if match is None:
        return None
    return (int(match.group(1)), int(match.group(2)), int(match.group(3)))


def _capture_enabled(policy: HostPolicy, key: str) -> bool:
    return policy.capture_policy.get(key) == "full_local_default"


def _validate_otlp_http_endpoint(value: JsonValue | None, field_name: str, expected_path: str) -> str:
    endpoint = _string_value(value)
    if endpoint is None:
        raise BootstrapError(f"{field_name} endpoint must be a string")
    parsed = _validate_http_url(endpoint, field_name)
    if parsed.path != expected_path:
        raise BootstrapError(f"{field_name} endpoint must use path {expected_path}")
    return endpoint


def _validate_http_url(value: str, field_name: str) -> SplitResult:
    parsed = urlsplit(value)
    if parsed.scheme not in {"http", "https"} or parsed.netloc == "":
        raise BootstrapError(f"{field_name} endpoint must be an absolute HTTP(S) URL")
    if parsed.username is not None or parsed.password is not None or parsed.query or parsed.fragment:
        raise BootstrapError(f"{field_name} endpoint must not include credentials, query, or fragment")
    return parsed


def _datetime_value(value: JsonValue | None, field_name: str) -> dt.datetime:
    text = _string_value(value)
    if text is None:
        raise BootstrapError(f"{field_name} must be an ISO timestamp")
    try:
        parsed = dt.datetime.fromisoformat(text.replace("Z", "+00:00"))
    except ValueError as exc:
        raise BootstrapError(f"{field_name} must be an ISO timestamp") from exc
    if parsed.tzinfo is None or parsed.utcoffset() is None:
        raise BootstrapError(f"{field_name} must include a timezone")
    return parsed


def _optional_datetime_value(value: JsonValue | None, field_name: str) -> dt.datetime | None:
    if value is None:
        return None
    return _datetime_value(value, field_name)


def _int_value(value: JsonValue | None, field_name: str) -> int:
    if type(value) is not int:
        raise BootstrapError(f"{field_name} must be an integer")
    return value


def _optional_int_value(value: JsonValue | None) -> int | None:
    if type(value) is not int:
        return None
    return value


def _decode_json_object(body: bytes, label: str) -> dict[str, JsonValue]:
    try:
        value = json.loads(body.decode())
    except json.JSONDecodeError as exc:
        raise BootstrapError(f"{label} is invalid JSON: {exc.msg}") from exc
    if not isinstance(value, dict):
        raise BootstrapError(f"{label} must be a JSON object")
    return _json_object(value)


def _json_object(value: dict[object, object]) -> dict[str, JsonValue]:
    result: dict[str, JsonValue] = {}
    for key, child in value.items():
        if not isinstance(key, str):
            raise BootstrapError("JSON object contains a non-string key")
        result[key] = _json_value(child)
    return result


def _json_value(value: object) -> JsonValue:
    if value is None or isinstance(value, str | int | float | bool):
        return value
    if isinstance(value, list):
        return [_json_value(child) for child in value]
    if isinstance(value, dict):
        return _json_object(value)
    raise BootstrapError(f"unsupported JSON value: {type(value).__name__}")


def _json_mapping_or_empty(value: JsonValue | None) -> dict[str, JsonValue]:
    if not isinstance(value, dict):
        return {}
    return value


def _normalize_base_url(value: str) -> str:
    normalized = value.rstrip("/")
    parsed = _validate_http_url(normalized, "worker base URL")
    _validate_worker_transport(parsed, "worker base URL")
    if parsed.path not in {"", "/"}:
        raise BootstrapError("worker base URL must not include a path")
    return normalized


def _test_url_overrides_enabled() -> bool:
    return os.environ.get(TEST_URL_OVERRIDE_ENV) == "1"


def _is_loopback_parsed_url(parsed: SplitResult) -> bool:
    host = parsed.hostname
    return host in {"localhost", "127.0.0.1", "::1"}


def _validate_worker_transport(parsed: SplitResult, field_name: str) -> None:
    if parsed.scheme == "https":
        return
    if _test_url_overrides_enabled() and _is_loopback_parsed_url(parsed):
        return
    raise BootstrapError(f"{field_name} must use HTTPS unless {TEST_URL_OVERRIDE_ENV}=1 and the host is loopback")


def _string_value(value: object) -> str | None:
    if isinstance(value, str):
        return value
    return None


def _runtime_target(value: object, fallback: Host) -> Host:
    if value == "codex" or value == "claude":
        return value
    return fallback


def _non_empty(value: str | None) -> str | None:
    if value is None or value.strip() == "":
        return None
    return value


def _otel_headers(headers: dict[str, str]) -> str:
    return ",".join(f"{name}={value}" for name, value in sorted(headers.items()))


def _toml_inline_headers(headers: dict[str, str]) -> str:
    values = ", ".join(f"{_toml_string(name)} = {_toml_string(value)}" for name, value in sorted(headers.items()))
    return "{ " + values + " }"


def _toml_string(value: str) -> str:
    return json.dumps(value)


def _toml_bool(value: bool) -> str:
    return "true" if value else "false"


def _env_bool(value: bool) -> str:
    return "1" if value else "0"


def _self_sha256() -> str:
    return hashlib.sha256(Path(__file__).read_bytes()).hexdigest()


def _emit(
    payload: dict[str, JsonValue],
    *,
    quiet: bool = False,
    stream: TextIO | None = None,
    update_notice: str | None = None,
) -> None:
    if quiet:
        return
    output = dict(payload)
    # Both Claude and Codex surface a SessionStart hook's `systemMessage` to the user; raw stdout
    # is only added to the model context. The status JSON stays in the payload for manual
    # troubleshooting; the extra field is ignored by the host hook parsers.
    # https://code.claude.com/docs/en/hooks  https://developers.openai.com/codex/hooks
    messages = [message for message in (update_notice, _enrollment_user_message(payload)) if message is not None]
    if messages:
        output["systemMessage"] = " ".join(messages)
    output_stream = stream or sys.stdout
    output_stream.write(json.dumps(_redact_json(output), sort_keys=True) + "\n")
    output_stream.flush()


@dataclass(frozen=True)
class HostDisplay:
    """Human-facing host name and user config path used in SessionStart messages."""

    name: str
    config_path: str


HOST_DISPLAY_NAMES: dict[str, HostDisplay] = {
    "claude": HostDisplay(name="Claude Code", config_path="~/.claude/settings.json"),
    "codex": HostDisplay(name="Codex", config_path="~/.codex/config.toml"),
}


def _enrollment_user_message(payload: dict[str, JsonValue]) -> str | None:
    """Return a user-facing enrollment-status message for the host, or None to stay silent.

    Both Claude and Codex surface a message, and only for outcomes worth showing on a hook that
    runs every startup/resume: a fresh config write, a pending browser approval, or a block. The
    steady "already configured", gate-disabled, and error states stay silent so the hook does not
    banner every session (errors still reach stderr/the debug log).
    """

    host_label = HOST_DISPLAY_NAMES.get(_string_value(payload.get("host")) or "")
    if host_label is None:
        return None
    status = payload.get("status")
    if status == "needs_restart":
        return f"Promptless telemetry configured for {host_label.name}. Restart {host_label.name} to start telemetry."
    if status == "setup_pending":
        return (
            "Promptless host enrollment is awaiting browser approval. "
            f"Approve in the browser tab that opened, then restart {host_label.name}."
        )
    if status == "blocked":
        if payload.get("reason") == "bootstrap_upgrade_required":
            return "Promptless host enrollment is blocked: a newer Promptless bootstrap runtime is required."
        return (
            "Promptless host enrollment is blocked: existing telemetry settings were left unchanged. "
            f"Review {host_label.config_path}."
        )
    return None


def _redact_json(value: JsonValue) -> JsonValue:
    if isinstance(value, str):
        return _redact_text(value)
    if isinstance(value, list):
        return [_redact_json(child) for child in value]
    if isinstance(value, dict):
        redacted: dict[str, JsonValue] = {}
        for key, child in value.items():
            if key.lower() in {"authorization", "device_code", "host_credential", "token"}:
                redacted[key] = "<redacted>"
            else:
                redacted[key] = _redact_json(child)
        return redacted
    return value


def _redact_text(value: str) -> str:
    redacted = re.sub(r"Bearer\s+[A-Za-z0-9._~+/=-]+", "Bearer <redacted>", value)
    redacted = re.sub(r"plihost_[A-Za-z0-9._~+/=-]+", "plihost_<redacted>", redacted)
    return re.sub(r"plihenroll_[A-Za-z0-9._~+/=-]+", "plihenroll_<redacted>", redacted)


