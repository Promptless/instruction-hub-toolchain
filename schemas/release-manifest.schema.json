{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.promptless.ai/instruction-hub-release-manifest.schema.json",
  "title": "Promptless Instruction Hub Release Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "org",
    "plugin",
    "stable_packages",
    "targets",
    "target_hashes",
    "managed_runtimes",
    "assets",
    "version_basis",
    "release_id",
    "release_hash"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "org": {
      "type": "string",
      "minLength": 1
    },
    "plugin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "version"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|[0-9A-Za-z-]*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9]\\d*|[0-9A-Za-z-]*[A-Za-z-][0-9A-Za-z-]*))*))?(?:\\+([0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*))?$"
        }
      }
    },
    "stable_packages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$"
      },
      "uniqueItems": true
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": ["claude", "codex", "gemini", "cursor"]
      },
      "uniqueItems": true
    },
    "target_hashes": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "claude": {
          "$ref": "#/$defs/sha256"
        },
        "codex": {
          "$ref": "#/$defs/sha256"
        },
        "gemini": {
          "$ref": "#/$defs/sha256"
        },
        "cursor": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "managed_runtimes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "channel",
          "executable",
          "hook",
          "package_id",
          "path",
          "plugin_id",
          "plugin_version",
          "sha256",
          "status",
          "target",
          "toolchain_version",
          "version"
        ],
        "properties": {
          "id": {
            "const": "native-trace-collector"
          },
          "package_id": {
            "type": "string",
            "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$"
          },
          "plugin_id": {
            "type": "string",
            "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$"
          },
          "plugin_version": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "const": "included"
          },
          "target": {
            "enum": ["claude", "codex"]
          },
          "toolchain_version": {
            "type": "string",
            "minLength": 1
          },
          "channel": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|[0-9A-Za-z-]*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9]\\d*|[0-9A-Za-z-]*[A-Za-z-][0-9A-Za-z-]*))*))?(?:\\+([0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*))?$"
          },
          "sha256": {
            "$ref": "#/$defs/sha256"
          },
          "executable": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "hook": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ref", "id", "type", "title", "source_path", "content_hash", "support"],
        "properties": {
          "ref": {
            "type": "string",
            "pattern": "^(skill|rule|agent|command|hook|mcp):[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$"
          },
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$"
          },
          "type": {
            "enum": ["skill", "rule", "agent", "command", "hook", "mcp"]
          },
          "title": {
            "type": ["string", "null"]
          },
          "source_path": {
            "type": ["string", "null"]
          },
          "content_hash": {
            "$ref": "#/$defs/sha256"
          },
          "support": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "claude": {
                "$ref": "#/$defs/target_support"
              },
              "codex": {
                "$ref": "#/$defs/target_support"
              },
              "gemini": {
                "$ref": "#/$defs/target_support"
              },
              "cursor": {
                "$ref": "#/$defs/target_support"
              }
            }
          }
        }
      }
    },
    "version_basis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "org",
        "plugin",
        "stable_packages",
        "targets",
        "packages",
        "target_hashes",
        "managed_runtimes"
      ],
      "properties": {
        "org": {
          "type": "string",
          "minLength": 1
        },
        "plugin": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "name", "version"],
          "properties": {
            "id": {
              "type": "string",
              "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$"
            },
            "name": {
              "type": "string",
              "minLength": 1
            },
            "version": {
              "type": "string",
              "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|[0-9A-Za-z-]*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9]\\d*|[0-9A-Za-z-]*[A-Za-z-][0-9A-Za-z-]*))*))?(?:\\+([0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*))?$"
            }
          }
        },
        "stable_packages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$"
          },
          "uniqueItems": true
        },
        "targets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": ["claude", "codex", "gemini", "cursor"]
          },
          "uniqueItems": true
        },
        "packages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "name", "includes", "assets"],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$"
              },
              "name": {
                "type": "string",
                "minLength": 1
              },
              "includes": {
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^(skill|rule|agent|command|hook|mcp):[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$"
                },
                "uniqueItems": true
              },
              "assets": {
                "type": "array",
                "items": {
                  "$ref": "#/properties/assets/items"
                }
              }
            }
          }
        },
        "target_hashes": {
          "$ref": "#/properties/target_hashes"
        },
        "managed_runtimes": {
          "$ref": "#/properties/managed_runtimes"
        }
      }
    },
    "release_id": {
      "type": "string",
      "minLength": 1
    },
    "release_hash": {
      "$ref": "#/$defs/sha256"
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "target_support": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "allOf": [
        {
          "if": {
            "properties": {
              "mode": {
                "const": "unsupported"
              }
            },
            "required": ["mode"]
          },
          "then": {
            "required": ["reason"]
          }
        }
      ],
      "properties": {
        "mode": {
          "enum": ["agent-skill", "native", "projected", "unsupported"]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
