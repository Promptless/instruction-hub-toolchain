{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.promptless.ai/instruction-hub-release-manifest.schema.json",
  "title": "Promptless Instruction Hub Release Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "org",
    "plugin",
    "stable_packages",
    "targets",
    "target_hashes",
    "managed_runtimes",
    "assets",
    "release_id",
    "release_hash"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "org": {
      "type": "string",
      "minLength": 1
    },
    "plugin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "version"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|[0-9A-Za-z-]*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9]\\d*|[0-9A-Za-z-]*[A-Za-z-][0-9A-Za-z-]*))*))?(?:\\+([0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*))?$"
        }
      }
    },
    "stable_packages": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$"
      },
      "uniqueItems": true
    },
    "targets": {
      "type": "array",
      "items": {
        "enum": ["claude", "codex", "gemini", "cursor"]
      },
      "uniqueItems": true
    },
    "target_hashes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "claude": {
          "$ref": "#/$defs/sha256"
        },
        "codex": {
          "$ref": "#/$defs/sha256"
        },
        "gemini": {
          "$ref": "#/$defs/sha256"
        },
        "cursor": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "managed_runtimes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "package_id",
          "plugin_id",
          "plugin_version",
          "status",
          "target",
          "toolchain_version"
        ],
        "oneOf": [
          {
            "properties": {
              "status": {
                "const": "included"
              }
            },
            "required": ["channel", "version", "sha256", "executable", "path", "hook"],
            "not": {
              "required": ["reason"]
            }
          },
          {
            "properties": {
              "status": {
                "const": "unsupported"
              }
            },
            "required": ["reason"],
            "not": {
              "anyOf": [
                {
                  "required": ["channel"]
                },
                {
                  "required": ["version"]
                },
                {
                  "required": ["sha256"]
                },
                {
                  "required": ["executable"]
                },
                {
                  "required": ["path"]
                },
                {
                  "required": ["hook"]
                }
              ]
            }
          }
        ],
        "properties": {
          "id": {
            "const": "host-enrollment-bootstrap"
          },
          "package_id": {
            "type": "string",
            "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$"
          },
          "plugin_id": {
            "type": "string",
            "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$"
          },
          "plugin_version": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": ["included", "unsupported"]
          },
          "target": {
            "enum": ["claude", "codex", "gemini", "cursor"]
          },
          "toolchain_version": {
            "type": "string",
            "minLength": 1
          },
          "channel": {
            "const": "stable"
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "$ref": "#/$defs/sha256"
          },
          "executable": {
            "const": "promptless-host-enrollment-bootstrap"
          },
          "path": {
            "const": "bin/promptless-host-enrollment-bootstrap"
          },
          "hook": {
            "const": "hooks/hooks.json"
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ref", "id", "type", "title", "source_path", "content_hash", "support"],
        "properties": {
          "ref": {
            "type": "string",
            "pattern": "^(skill|rule|agent|command|hook|mcp):[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$"
          },
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$"
          },
          "type": {
            "enum": ["skill", "rule", "agent", "command", "hook", "mcp"]
          },
          "title": {
            "type": ["string", "null"]
          },
          "source_path": {
            "type": ["string", "null"]
          },
          "content_hash": {
            "$ref": "#/$defs/sha256"
          },
          "support": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "claude": {
                "$ref": "#/$defs/target_support"
              },
              "codex": {
                "$ref": "#/$defs/target_support"
              },
              "gemini": {
                "$ref": "#/$defs/target_support"
              },
              "cursor": {
                "$ref": "#/$defs/target_support"
              }
            }
          }
        }
      }
    },
    "release_id": {
      "type": "string",
      "minLength": 1
    },
    "release_hash": {
      "$ref": "#/$defs/sha256"
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "target_support": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "allOf": [
        {
          "if": {
            "properties": {
              "mode": {
                "const": "unsupported"
              }
            },
            "required": ["mode"]
          },
          "then": {
            "required": ["reason"]
          }
        }
      ],
      "properties": {
        "mode": {
          "enum": ["agent-skill", "native", "projected", "unsupported"]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
