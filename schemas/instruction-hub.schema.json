{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.promptless.ai/instruction-hub.schema.json",
  "title": "Promptless Instruction Hub Config",
  "type": "object",
  "additionalProperties": false,
  "required": ["org", "plugin_id", "plugin_name", "plugin_version"],
  "properties": {
    "org": {
      "type": "string",
      "minLength": 1
    },
    "plugin_id": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$"
    },
    "plugin_name": {
      "type": "string",
      "minLength": 1
    },
    "plugin_version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|[0-9A-Za-z-]*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9]\\d*|[0-9A-Za-z-]*[A-Za-z-][0-9A-Za-z-]*))*))?(?:\\+([0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*))?$"
    },
    "stable_packages": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$"
      },
      "uniqueItems": true,
      "default": ["core"]
    },
    "targets": {
      "type": "array",
      "items": {
        "enum": ["claude", "codex", "gemini", "cursor"]
      },
      "uniqueItems": true,
      "default": ["claude", "codex", "gemini", "cursor"]
    }
  }
}
